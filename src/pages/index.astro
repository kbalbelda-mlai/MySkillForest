---
import {
  loadForestData,
} from "../scripts/loadForestData";

import ForestWorld from "../components/forest/ForestWorld.astro";
import PatchViewerDialog from "../components/dialogs/PatchViewerDialog.astro";
import AboutDialog from "../components/dialogs/AboutDialog.astro";
import AddPatchDialog from "../components/dialogs/AddPatchDialog.astro";
import EditPatchDialog from "../components/dialogs/EditPatchDialog.astro";
import PlantTreeDialog from "../components/dialogs/PlantTreeDialog.astro";
import EditTreeDialog from "../components/dialogs/EditTreeDialog.astro";
import ChopTreeDialog from "../components/dialogs/ChopTreeDialog.astro";
import DeletePatchDialog from "../components/dialogs/DeletePatchDialog.astro";

/* =========================================================
   PAGE DATA
   ========================================================= */

const pageTitle = "My Skill Forest";

const {
  patches: forestPatches,
  trees,
  statistics,
  treeSearchIndex,
} = await loadForestData();

console.log("Index page forest data:", {
  forestPatches,
  trees,
  statistics,
  treeSearchIndex,
});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />

    <meta
      name="viewport"
      content="width=device-width"
    />

    <title>{pageTitle}</title>
  </head>

  <body data-current-mode="strolling">
    <script
      id="initial-forest-patches"
      type="application/json"
      set:html={JSON.stringify(forestPatches)}
    ></script>

    <script
      id="initial-forest-trees"
      type="application/json"
      set:html={JSON.stringify(trees)}
    ></script>

    <header class="header-ribbon">

      <div
        class="mode-indicator"
        data-mode-indicator
        aria-live="polite"
      >
        Strolling Mode
      </div>

      <nav
        class="main-nav"
        aria-label="Forest navigation"
      >
        <button
          type="button"
          data-home-button
        >
          Home
        </button>

        <button
          type="button"
          data-about-button
        >
          About
        </button>
      </nav>

      <div
        class="tree-search"
        data-tree-search
      >
        <label
          class="visually-hidden"
          for="tree-search-input"
        >
          Search for a tree
        </label>

        <div class="tree-search-input-wrapper">
          <span
            class="tree-search-icon"
            aria-hidden="true"
          >
            ⌕
          </span>

          <input
            id="tree-search-input"
            class="tree-search-input"
            type="text"
            placeholder="Search trees..."
            autocomplete="off"
            spellcheck="false"
            aria-autocomplete="list"
            aria-controls="tree-search-results"
            aria-expanded="false"
            data-tree-search-input
          />

          <button
            class="tree-search-clear"
            type="button"
            aria-label="Clear tree search"
            data-tree-search-clear
            hidden
          >
            ×
          </button>
        </div>

        <div
          id="tree-search-results"
          class="tree-search-results"
          role="listbox"
          aria-label="Tree search results"
          data-tree-search-results
          hidden
        >
          {
            treeSearchIndex.map(
              (record) => (
                <button
                  class="tree-search-result"
                  type="button"
                  role="option"
                  data-tree-search-result
                  data-tree-id={record.treeId}
                  data-tree-name={
                    record.treeName
                  }
                  data-patch-id={
                    record.patchId
                  }
                  data-patch-name={
                    record.patchName
                  }
                  data-normalized-tree-name={
                    record.normalizedTreeName
                  }
                  data-normalized-patch-name={
                    record.normalizedPatchName
                  }
                  hidden
                >
                  <span
                    class="search-result-tree-name"
                  >
                    {record.treeName}
                  </span>

                  <span
                    class="search-result-patch-name"
                  >
                    {record.patchName}
                  </span>
                </button>
              ),
            )
          }

          <div
            class="tree-search-empty"
            data-tree-search-empty
            hidden
          >
            No matching trees found.
          </div>
        </div>
      </div>

      <div
        class="forest-stats"
        aria-label="Forest statistics"
      >
		<span>
  		  <strong>Patches:</strong>

  		  <span data-patch-count>
    		{statistics.patchCount}
  		  </span>
		</span>

        <span>
          <strong>Saplings:</strong>
          <span data-sapling-count>
		    {statistics.saplingCount}
		  </span>
        </span>

        <span>
          <strong>Trees:</strong>
          <span data-tree-count>
		    {statistics.treeCount}
          </span>
		</span>
      </div>
    </header>

    <main class="forest-viewport">
      <ForestWorld />

      <!-- =================================================
           MODE TOGGLE
           ================================================= -->

      <div class="left-control-area">
        <!-- ===============================================
             STROLLING / PLANTING MODE
             =============================================== -->
      
        <div class="mode-toggle-area">
          <button
            class="mode-toggle-button"
            type="button"
            aria-label="Switch to Planting Mode"
            aria-pressed="false"
            title="Switch to Planting Mode"
            data-mode-toggle
          >
            <span class="mode-toggle-image-frame">
              <img
                class="mode-toggle-image is-visible"
                src="/assets/ui/Mode_Button_Stroll.png"
                alt=""
                aria-hidden="true"
                draggable="false"
                data-mode-image-stroll
              />
      
              <img
                class="mode-toggle-image"
                src="/assets/ui/Mode_Button_Plant.png"
                alt=""
                aria-hidden="true"
                draggable="false"
                data-mode-image-plant
              />
            </span>
          </button>
      
          <div
            class="mode-toggle-label"
            data-mode-toggle-label
          >
            Switch to Planting
          </div>
        </div>
      
        <!-- ===============================================
             INTERACTION TOOLS
             =============================================== -->
      
        <div
          class="interaction-tools"
          role="toolbar"
          aria-label="Forest interaction tools"
        >
          <button
            class="interaction-tool-button is-selected"
            type="button"
            aria-label="Cursor tool"
            aria-pressed="true"
            title="Cursor Tool"
            data-tooltip="Cursor Tool"
            data-interaction-tool="cursor"
          >
            <img
              src="/assets/ui/Tool_Cursor.png"
              alt=""
              aria-hidden="true"
              draggable="false"
            />
      
            <span
              class="tool-active-indicator"
              aria-hidden="true"
            ></span>
          </button>
      
          <button
            class="interaction-tool-button"
            type="button"
            aria-label="Pan tool. Hold Shift to temporarily pan."
            aria-pressed="false"
            title="Pan Tool — Hold Shift to temporarily pan"
            data-tooltip="Hold Shift Key to autoselect Pan"
            data-interaction-tool="pan"
          >
            <img
              src="/assets/ui/Tool_Pan.png"
              alt=""
              aria-hidden="true"
              draggable="false"
            />
      
            <span
              class="tool-active-indicator"
              aria-hidden="true"
            ></span>
          </button>
        </div>
      </div>

      <!-- =================================================
           PATCH OPERATIONS
           ================================================= -->

      <div
        class="patch-operations"
        aria-label="Patch operations"
        aria-hidden="true"
        data-patch-operations
      >
        <button
          class="patch-operation-button primary"
          type="button"
          data-add-patch-button
        >
          Add Patch
        </button>

        <button
          class="patch-operation-button danger"
          type="button"
          data-delete-patch-button
          title="Select a patch to delete"
        >
          Delete Patch
        </button>
      </div>
    </main>

    <PatchViewerDialog />

    <AboutDialog />

    <AddPatchDialog />

    <EditPatchDialog />

    <PlantTreeDialog />

    <EditTreeDialog />

    <ChopTreeDialog />

    <DeletePatchDialog />

    <div class="delete-patch-hint" data-delete-patch-hint hidden>Hit ESC to Cancel</div>
  </body>
</html>

<style>
  /* =======================================================
     GLOBAL
     ======================================================= */

  :global(*) {
    box-sizing: border-box;
  }

  :global(html),
  :global(body) {
    width: 100%;
    height: 100%;

    margin: 0;

    overflow: hidden;

    font-family:
      Arial,
      sans-serif;
  }

  body {
    display: flex;
    flex-direction: column;

    background: #b8dce8;
  }

  button,
  input {
    font: inherit;
  }

  .visually-hidden {
    position: absolute;

    width: 1px;
    height: 1px;

    padding: 0;
    margin: -1px;

    overflow: hidden;

    clip: rect(0, 0, 0, 0);
    white-space: nowrap;

    border: 0;
  }

  /* =======================================================
     HEADER RIBBON
     ======================================================= */

  .header-ribbon {
    position: relative;
    z-index: 1000;

    min-height: 64px;
    flex-shrink: 0;

    display: flex;
    align-items: center;

    gap: 18px;

    padding:
      8px 20px;

    background:
      rgba(255, 255, 255, 0.94);

    border-bottom:
      1px solid
      rgba(0, 0, 0, 0.15);

    box-shadow:
      0 4px 18px
      rgba(23, 72, 89, 0.08);
  }

  .mode-indicator {
    flex-shrink: 0;

    min-width: 138px;

    padding:
      10px 14px;

    border:
      1px solid
      rgba(56, 126, 76, 0.18);

    border-radius: 8px;

    background: #dcefdc;

    color: #254c33;

    font-weight: 700;

    text-align: center;
    white-space: nowrap;

    transition:
      color 220ms ease,
      background 220ms ease,
      border-color 220ms ease,
      transform 220ms ease;
  }

  body[data-current-mode="planting"]
  .mode-indicator {
    border-color:
      rgba(37, 109, 148, 0.26);

    background: #dceefa;

    color: #174e6b;
  }

  .mode-indicator.is-changing {
    animation:
      mode-indicator-pulse
      300ms ease;
  }

  @keyframes mode-indicator-pulse {
    0% {
      transform: scale(1);
    }

    50% {
      transform: scale(1.06);
    }

    100% {
      transform: scale(1);
    }
  }

  /* =======================================================
     NAVIGATION
     ======================================================= */

  .main-nav {
    display: flex;
    align-items: center;

    gap: 4px;

    flex-shrink: 0;
  }

  .main-nav button {
    border: 0;

    border-radius: 8px;

    background: transparent;

    padding:
      10px 12px;

    color: #183f50;

    cursor: pointer;

    font-size: 15px;
    font-weight: 700;

    transition:
      background 150ms ease,
      transform 150ms ease;
  }

  .main-nav button:hover {
    background:
      rgba(23, 104, 135, 0.10);
  }

  .main-nav button:active {
    transform: scale(0.97);
  }

  .main-nav button:focus-visible {
    outline:
      3px solid
      rgba(67, 172, 220, 0.75);

    outline-offset: 2px;
  }

  /* =======================================================
     TREE SEARCH
     ======================================================= */

  .tree-search {
    position: relative;

    width:
      min(360px, 30vw);

    min-width: 210px;
  }

  .tree-search-input-wrapper {
    position: relative;

    display: flex;
    align-items: center;

    width: 100%;
  }

  .tree-search-icon {
    position: absolute;
    left: 12px;
    z-index: 2;

    color: #52717d;

    font-size: 19px;

    pointer-events: none;
  }

  .tree-search-input {
    width: 100%;
    height: 42px;

    padding:
      8px 40px 8px 38px;

    border:
      1px solid
      rgba(44, 91, 108, 0.32);

    border-radius: 10px;

    background:
      rgba(246, 252, 254, 0.96);

    color: #173c4b;

    outline: none;

    transition:
      border-color 150ms ease,
      box-shadow 150ms ease,
      background 150ms ease;
  }

  .tree-search-input::placeholder {
    color: #708993;
  }

  .tree-search-input:hover {
    background: white;
  }

  .tree-search-input:focus {
    border-color: #3d9cc2;

    background: white;

    box-shadow:
      0 0 0 3px
      rgba(74, 177, 218, 0.18);
  }

  .tree-search-clear {
    position: absolute;
    right: 7px;
    z-index: 3;

    width: 30px;
    height: 30px;

    display: grid;
    place-items: center;

    padding: 0;

    border: 0;
    border-radius: 50%;

    background: transparent;

    color: #52717d;

    font-size: 22px;
    line-height: 1;

    cursor: pointer;
  }

  .tree-search-clear:hover {
    background:
      rgba(23, 104, 135, 0.10);
  }

  .tree-search-results {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    right: 0;
    z-index: 4000;

    max-height: 360px;

    overflow-y: auto;

    padding: 7px;

    border:
      1px solid
      rgba(29, 84, 104, 0.26);

    border-radius: 12px;

    background:
      rgba(255, 255, 255, 0.98);

    box-shadow:
      0 16px 34px
      rgba(17, 62, 80, 0.22);

    backdrop-filter: blur(8px);
  }

  .tree-search-result {
    width: 100%;

    display: flex;
    flex-direction: column;
    align-items: flex-start;

    gap: 4px;

    padding:
      11px 12px;

    border: 0;
    border-radius: 8px;

    background: transparent;

    color: #153b4a;

    text-align: left;

    cursor: pointer;

    transition:
      background 140ms ease,
      transform 140ms ease;
  }

  .tree-search-result:hover,
  .tree-search-result.is-active {
    background:
      linear-gradient(
        135deg,
        rgba(224, 247, 255, 0.98),
        rgba(204, 232, 251, 0.98)
      );
  }

  .tree-search-result:active {
    transform: scale(0.99);
  }

  .tree-search-result:focus-visible {
    outline:
      3px solid
      rgba(58, 160, 207, 0.55);

    outline-offset: -2px;
  }

  .search-result-tree-name {
    font-size: 15px;
    font-weight: 800;

    line-height: 1.25;

    overflow-wrap: anywhere;
  }

  .search-result-patch-name {
    color: #5d7680;

    font-size: 12px;
    font-weight: 600;

    line-height: 1.3;

    overflow-wrap: anywhere;
  }

  .tree-search-empty {
    padding:
      18px 14px;

    color: #647b84;

    font-size: 14px;
    font-weight: 700;

    text-align: center;
  }

  .tree-search-result[hidden],
  .tree-search-empty[hidden],
  .tree-search-results[hidden],
  .tree-search-clear[hidden] {
    display: none !important;
  }

  /* =======================================================
     STATISTICS
     ======================================================= */

  .forest-stats {
    margin-left: auto;

    display: flex;
    align-items: center;

    gap: 18px;

    flex-shrink: 0;

    color: #294d5c;

    font-size: 14px;

    white-space: nowrap;
  }

  .forest-stats span {
    display: inline-flex;
    gap: 4px;
  }

  /* =======================================================
     FOREST VIEWPORT
     ======================================================= */

  .forest-viewport {
    position: relative;

    flex: 1;

    overflow: hidden;

    background: #b8dce8;
  }

  /* =======================================================
     FLOATING MODE TOGGLE
     ======================================================= */

  .left-control-area {
    position: absolute;
    top: 20px;
    left: 20px;
    z-index: 800;
  
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  
    gap: 12px;
  }
  
  .mode-toggle-area {
    display: flex;
    align-items: center;
  
    gap: 12px;
  }

  .mode-toggle-button {
    position: relative;

    width: 76px;
    height: 76px;

    flex-shrink: 0;

    padding: 0;

    overflow: hidden;

    border:
      3px solid
      rgba(255, 255, 255, 0.95);

    border-radius: 22px;

    background:
      rgba(255, 255, 255, 0.92);

    box-shadow:
      0 10px 24px
      rgba(14, 65, 84, 0.24);

    cursor: pointer;

    transition:
      transform 180ms ease,
      box-shadow 220ms ease,
      border-color 220ms ease;
  }

  .mode-toggle-button:hover {
    transform:
      translateY(-2px)
      scale(1.025);

    box-shadow:
      0 14px 30px
      rgba(14, 65, 84, 0.30);
  }

  .mode-toggle-button:active {
    transform:
      translateY(1px)
      scale(0.94);
  }

  .mode-toggle-button:focus-visible {
    outline:
      4px solid
      rgba(82, 189, 236, 0.82);

    outline-offset: 4px;
  }

  body[data-current-mode="planting"]
  .mode-toggle-button {
    border-color:
      rgba(114, 213, 255, 0.95);

    box-shadow:
      0 0 0 5px
      rgba(78, 178, 222, 0.18),
      0 12px 30px
      rgba(26, 110, 148, 0.34);
  }

  .mode-toggle-button.is-switching {
    animation:
      mode-toggle-switch
      420ms
      cubic-bezier(
        0.34,
        1.56,
        0.64,
        1
      );
  }

  @keyframes mode-toggle-switch {
    0% {
      transform:
        scale(1)
        rotate(0deg);
    }

    42% {
      transform:
        scale(0.82)
        rotate(-7deg);
    }

    72% {
      transform:
        scale(1.08)
        rotate(4deg);
    }

    100% {
      transform:
        scale(1)
        rotate(0deg);
    }
  }

  .mode-toggle-image-frame {
    position: relative;

    display: block;

    width: 100%;
    height: 100%;

    overflow: hidden;

    border-radius: 19px;
  }

  .mode-toggle-image {
    position: absolute;
    inset: 0;

    width: 100%;
    height: 100%;

    display: block;

    object-fit: cover;

    opacity: 0;

    transform:
      scale(1.10)
      rotate(-4deg);

    transition:
      opacity 220ms ease,
      transform 320ms
      cubic-bezier(
        0.34,
        1.56,
        0.64,
        1
      );

    pointer-events: none;

    user-select: none;
    -webkit-user-drag: none;
  }

  .mode-toggle-image.is-visible {
    opacity: 1;

    transform:
      scale(1)
      rotate(0deg);
  }

  .mode-toggle-label {
    max-width: 150px;

    padding:
      8px 12px;

    border:
      1px solid
      rgba(32, 84, 103, 0.16);

    border-radius: 10px;

    background:
      rgba(255, 255, 255, 0.88);

    box-shadow:
      0 7px 17px
      rgba(22, 69, 86, 0.13);

    color: #214c5d;

    font-size: 13px;
    font-weight: 700;
    line-height: 1.25;

    pointer-events: none;

    transition:
      color 220ms ease,
      background 220ms ease;
  }

  body[data-current-mode="planting"]
  .mode-toggle-label {
    background:
      rgba(222, 243, 253, 0.94);

    color: #145370;
  }

  /* =======================================================
     INTERACTION TOOLS
     ======================================================= */
  
  .interaction-tools {
    display: flex;
    flex-direction: column;
  
    gap: 8px;
  
    padding: 7px;
  
    border:
      1px solid
      rgba(33, 91, 113, 0.20);
  
    border-radius: 14px;
  
    background:
      rgba(255, 255, 255, 0.88);
  
    box-shadow:
      0 8px 20px
      rgba(17, 68, 88, 0.18);
  
    backdrop-filter: blur(6px);
  }
  
  .interaction-tool-button {
    position: relative;
  
    width: 46px;
    height: 46px;
  
    display: grid;
    place-items: center;
  
    padding: 4px;
  
    border:
      2px solid
      transparent;
  
    border-radius: 11px;
  
    background:
      rgba(241, 249, 252, 0.92);
  
    box-shadow:
      0 3px 8px
      rgba(20, 72, 91, 0.10);
  
    cursor: pointer;
  
    opacity: 0.66;
  
    transition:
      opacity 160ms ease,
      transform 160ms ease,
      border-color 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease;
  }
  
  .interaction-tool-button img {
    width: 100%;
    height: 100%;
  
    display: block;
  
    border-radius: 7px;
  
    object-fit: cover;
  
    pointer-events: none;
  
    user-select: none;
    -webkit-user-drag: none;
  }
  
  .interaction-tool-button:hover {
    opacity: 0.92;
  
    transform:
      translateY(-1px)
      scale(1.03);
  }
  
  .interaction-tool-button:active {
    transform:
      translateY(1px)
      scale(0.90);
  }
  
  .interaction-tool-button:focus-visible {
    outline:
      3px solid
      rgba(62, 171, 218, 0.78);
  
    outline-offset: 3px;
  }
  
  .interaction-tool-button.is-selected {
    border-color:
      rgba(47, 158, 207, 0.92);
  
    background:
      rgba(224, 246, 255, 0.98);
  
    box-shadow:
      0 0 0 4px
      rgba(57, 169, 217, 0.17),
      0 7px 16px
      rgba(22, 101, 137, 0.24);
  
    opacity: 1;
  
    transform:
      translateY(-1px);
  }
  
  .interaction-tool-button.is-temporary {
    border-color:
      rgba(72, 184, 229, 0.95);
  
    box-shadow:
      0 0 0 5px
      rgba(72, 184, 229, 0.23),
      0 7px 17px
      rgba(22, 101, 137, 0.25);
  }
  
  .interaction-tool-button.is-animating {
    animation:
      interaction-tool-selected
      340ms
      cubic-bezier(
        0.34,
        1.56,
        0.64,
        1
      );
  }
  
  @keyframes interaction-tool-selected {
    0% {
      transform:
        scale(1);
    }
  
    45% {
      transform:
        scale(0.82)
        rotate(-5deg);
    }
  
    75% {
      transform:
        scale(1.10)
        rotate(3deg);
    }
  
    100% {
      transform:
        translateY(-1px)
        scale(1);
    }
  }
  
  .tool-active-indicator {
    position: absolute;
    right: -4px;
    bottom: -4px;
  
    width: 11px;
    height: 11px;
  
    border:
      2px solid white;
  
    border-radius: 50%;
  
    background: #35a9d8;
  
    box-shadow:
      0 2px 6px
      rgba(14, 77, 104, 0.32);
  
    opacity: 0;
    transform: scale(0.4);
  
    transition:
      opacity 160ms ease,
      transform 180ms ease;
  }
  
  .interaction-tool-button.is-selected
  .tool-active-indicator {
    opacity: 1;
    transform: scale(1);
  }
  
  /* Custom tooltip */
  
  .interaction-tool-button::after {
    position: absolute;
    left: calc(100% + 12px);
    top: 50%;
    z-index: 100;
  
    width: max-content;
    max-width: 220px;
  
    padding:
      7px 10px;
  
    border:
      1px solid
      rgba(36, 91, 111, 0.20);
  
    border-radius: 8px;
  
    background:
      rgba(255, 255, 255, 0.97);
  
    box-shadow:
      0 7px 17px
      rgba(15, 63, 81, 0.18);
  
    color: #214b5c;
  
    content:
      attr(data-tooltip);
  
    font-size: 12px;
    font-weight: 700;
    line-height: 1.3;
  
    opacity: 0;
    visibility: hidden;
  
    pointer-events: none;
  
    transform:
      translate(
        -5px,
        -50%
      );
  
    transition:
      opacity 150ms ease,
      visibility 150ms ease,
      transform 150ms ease;
  }
  
  .interaction-tool-button:hover::after,
  .interaction-tool-button:focus-visible::after {
    opacity: 1;
    visibility: visible;
  
    transform:
      translate(
        0,
        -50%
      );
  }

  /* =======================================================
     PATCH OPERATIONS
     ======================================================= */

  .patch-operations {
    position: absolute;
    top: 20px;
    right: 20px;
    z-index: 800;

    display: flex;
    align-items: center;

    gap: 10px;

    padding:
      10px;

    border:
      1px solid
      rgba(31, 94, 118, 0.20);

    border-radius: 14px;

    background:
      rgba(255, 255, 255, 0.92);

    box-shadow:
      0 10px 26px
      rgba(14, 65, 84, 0.20);

    opacity: 0;
    visibility: hidden;

    transform:
      translateY(-12px)
      scale(0.96);

    pointer-events: none;

    transition:
      opacity 220ms ease,
      visibility 220ms ease,
      transform 260ms
      cubic-bezier(
        0.34,
        1.56,
        0.64,
        1
      );
  }

  body[data-current-mode="planting"]
  .patch-operations {
    opacity: 1;
    visibility: visible;

    transform:
      translateY(0)
      scale(1);

    pointer-events: auto;
  }

  .patch-operation-button {
    min-height: 42px;

    padding:
      9px 16px;

    border:
      1px solid
      rgba(32, 91, 113, 0.24);

    border-radius: 10px;

    background:
      rgba(241, 249, 252, 0.96);

    color: #1c4c60;

    cursor: pointer;

    font-weight: 700;

    transition:
      background 160ms ease,
      transform 160ms ease,
      box-shadow 160ms ease;
  }

  .patch-operation-button.primary {
    border-color:
      rgba(26, 111, 147, 0.48);

    background: #176887;

    color: white;
  }

  .patch-operation-button.danger {
    border-color:
      rgba(150, 67, 67, 0.30);

    background:
      rgba(249, 238, 238, 0.96);

    color: #8c3f3f;
  }

  .patch-operation-button:hover:not(:disabled) {
    transform:
      translateY(-1px);

    box-shadow:
      0 6px 14px
      rgba(24, 89, 116, 0.18);
  }

  .patch-operation-button:active:not(:disabled) {
    transform:
      translateY(1px)
      scale(0.97);
  }

  .patch-operation-button:focus-visible {
    outline:
      3px solid
      rgba(68, 174, 220, 0.72);

    outline-offset: 2px;
  }

  .patch-operation-button:disabled {
    opacity: 0.46;

    cursor: not-allowed;
  }

  .delete-patch-hint {
    position: fixed; right: 24px; bottom: 24px; z-index: 4200;
    padding: 14px 18px; border: 2px solid #7d1717; border-radius: 12px;
    background: rgba(176, 38, 38, 0.96); color: white; font-weight: 900;
    box-shadow: 0 12px 30px rgba(90, 12, 12, 0.35);
  }
  .delete-patch-hint[hidden] { display: none !important; }
  body[data-delete-patch-mode="true"] .patch-operation-button.danger {
    background: #a72f2f; color: white; border-color: #7c2020;
  }

  /* =======================================================
     RESPONSIVE HEADER AND CONTROLS
     ======================================================= */

  @media (max-width: 950px) {
    .header-ribbon {
      flex-wrap: wrap;

      gap: 8px 14px;

      padding:
        8px 14px;
    }

    .tree-search {
      order: 3;

      width: 100%;
    }

    .forest-stats {
      margin-left: auto;
    }

    .left-control-area {
      top: 14px;
      left: 14px;
    }

    .patch-operations {
      top: 14px;
      right: 14px;
    }
  }

  @media (max-width: 700px) {
    .mode-toggle-label {
      display: none;
    }

    .mode-toggle-button {
      width: 64px;
      height: 64px;

      border-radius: 18px;
    }

    .mode-toggle-image-frame {
      border-radius: 15px;
    }

    .patch-operations {
      flex-direction: column;
      align-items: stretch;

      max-width: 145px;
    }

    .patch-operation-button {
      width: 100%;
    }
  }

  @media (max-width: 620px) {
    .mode-indicator {
      min-width: auto;
    }

    .forest-stats {
      width: 100%;

      justify-content: space-between;

      order: 4;

      margin-left: 0;

      padding:
        2px 4px;
    }

    .main-nav {
      flex: 1;
    }
  }
</style>

<script>
  /* =======================================================
     TYPES
     ======================================================= */

  import {
    initializeForestState,
    isForestStateInitialized,
  } from "../scripts/forestState";

  import type {
    ForestPatchRecord,
    TreeRecord,
  } from "../scripts/loadForestData";

  import type {
    ForestStateChangedDetail,
  } from "../scripts/forestState";

  type ForestMode =
    | "strolling"
    | "planting";

  type ForestInteractionTool =
    | "cursor"
    | "pan";
  
  interface ForestInteractionToolChangedDetail {
    tool: ForestInteractionTool;
    temporary: boolean;
  }

  interface PatchViewerOpenDetail {
    patchId: string;
    treeId?: string;
  }

  interface ForestModeChangedDetail {
    mode: ForestMode;
  }

  interface ForestModeRequestDetail {
    mode: ForestMode;
  }

  /* =======================================================
     ELEMENT REFERENCES
     ======================================================= */

  const initialPatchesData =
    document.querySelector<HTMLScriptElement>(
      "#initial-forest-patches",
    );

  const initialTreesData =
    document.querySelector<HTMLScriptElement>(
      "#initial-forest-trees",
    );

  const patchCountElement =
    document.querySelector<HTMLElement>(
      "[data-patch-count]",
    );

  const saplingCountElement =
    document.querySelector<HTMLElement>(
      "[data-sapling-count]",
    );

  const treeCountElement =
    document.querySelector<HTMLElement>(
      "[data-tree-count]",
    );

  const pageBody =
    document.body;

  const homeButton =
    document.querySelector<HTMLButtonElement>(
      "[data-home-button]",
    );

  const aboutButton =
    document.querySelector<HTMLButtonElement>(
      "[data-about-button]",
    );

  const modeIndicator =
    document.querySelector<HTMLElement>(
      "[data-mode-indicator]",
    );

  const modeToggleButton =
    document.querySelector<HTMLButtonElement>(
      "[data-mode-toggle]",
    );

  const strollModeImage =
    document.querySelector<HTMLImageElement>(
      "[data-mode-image-stroll]",
    );

  const plantModeImage =
    document.querySelector<HTMLImageElement>(
      "[data-mode-image-plant]",
    );

  const cursorToolButton =
    document.querySelector<HTMLButtonElement>(
      '[data-interaction-tool="cursor"]',
    );
  
  const panToolButton =
    document.querySelector<HTMLButtonElement>(
      '[data-interaction-tool="pan"]',
    );
  
  const interactionToolButtons =
    Array.from(
      document.querySelectorAll<HTMLButtonElement>(
        "[data-interaction-tool]",
      ),
    );

  const modeToggleLabel =
    document.querySelector<HTMLElement>(
      "[data-mode-toggle-label]",
    );

  const patchOperations =
    document.querySelector<HTMLElement>(
      "[data-patch-operations]",
    );

  const addPatchButton =
    document.querySelector<HTMLButtonElement>(
      "[data-add-patch-button]",
    );

  const deletePatchButton =
    document.querySelector<HTMLButtonElement>(
      "[data-delete-patch-button]",
    );

  const searchContainer =
    document.querySelector<HTMLElement>(
      "[data-tree-search]",
    );

  const searchInput =
    document.querySelector<HTMLInputElement>(
      "[data-tree-search-input]",
    );

  const clearSearchButton =
    document.querySelector<HTMLButtonElement>(
      "[data-tree-search-clear]",
    );

  const resultsPanel =
    document.querySelector<HTMLElement>(
      "[data-tree-search-results]",
    );

  const emptySearchMessage =
    document.querySelector<HTMLElement>(
      "[data-tree-search-empty]",
    );

  let searchResults = Array.from(
    document.querySelectorAll<HTMLButtonElement>(
      "[data-tree-search-result]",
    ),
  );

  let currentMode:
    ForestMode = "strolling";

  let manuallySelectedTool:
    ForestInteractionTool =
      "cursor";
  
  let effectiveInteractionTool:
    ForestInteractionTool =
      "cursor";
  
  let isShiftPanActive = false;
  
  let toolAnimationTimeout:
    number | undefined;

  let visibleResults:
    HTMLButtonElement[] = [];

  let activeResultIndex = -1;

  let modeAnimationTimeout:
    number | undefined;

  function parseInitialData<T>(
    element:
      HTMLScriptElement | null,
    fallback: T,
  ): T {
    if (!element) {
      console.warn(
        "Initial forest data element was not found.",
      );

      return fallback;
    }

    try {
      return JSON.parse(
        element.textContent ?? "",
      ) as T;
    } catch (error) {
      console.error(
        "Initial forest data could not be parsed:",
        error,
      );

      return fallback;
    }
  }

  /* =======================================================
     INTERACTION TOOL
     ======================================================= */
  
  function dispatchInteractionToolChanged(
    tool: ForestInteractionTool,
    temporary: boolean,
  ) {
    const detail:
      ForestInteractionToolChangedDetail = {
        tool,
        temporary,
      };
  
    window.dispatchEvent(
      new CustomEvent(
        "forest:interaction-tool-changed",
        {
          detail,
        },
      ),
    );
  }
  
  function animateInteractionTool(
    selectedButton:
      HTMLButtonElement | null,
  ) {
    if (!selectedButton) {
      return;
    }
  
    if (
      toolAnimationTimeout !==
      undefined
    ) {
      window.clearTimeout(
        toolAnimationTimeout,
      );
    }
  
    selectedButton.classList.remove(
      "is-animating",
    );
  
    void selectedButton.offsetWidth;
  
    selectedButton.classList.add(
      "is-animating",
    );
  
    toolAnimationTimeout =
      window.setTimeout(
        () => {
          selectedButton.classList.remove(
            "is-animating",
          );
        },
        360,
      );
  }
  
  function updateInteractionToolButtons(
    tool: ForestInteractionTool,
    temporary: boolean,
    animate = true,
  ) {
    interactionToolButtons.forEach(
      (button) => {
        const buttonTool =
          button.dataset
            .interactionTool as
            ForestInteractionTool;
  
        const isSelected =
          buttonTool === tool;
  
        button.classList.toggle(
          "is-selected",
          isSelected,
        );
  
        button.classList.toggle(
          "is-temporary",
          isSelected &&
          temporary,
        );
  
        button.setAttribute(
          "aria-pressed",
          String(isSelected),
        );
      },
    );
  
    if (animate) {
      animateInteractionTool(
        tool === "cursor"
          ? cursorToolButton
          : panToolButton,
      );
    }
  }
  
  function applyInteractionTool(
    tool: ForestInteractionTool,
    temporary = false,
    animate = true,
  ) {
    effectiveInteractionTool =
      tool;
  
    pageBody.dataset
      .interactionTool =
      tool;
  
    updateInteractionToolButtons(
      tool,
      temporary,
      animate,
    );
  
    dispatchInteractionToolChanged(
      tool,
      temporary,
    );
  
    console.log(
      "Forest interaction tool changed:",
      {
        tool,
        temporary,
        manuallySelectedTool,
      },
    );
  }
  
  function selectInteractionTool(
    tool: ForestInteractionTool,
  ) {
    manuallySelectedTool =
      tool;
  
    isShiftPanActive =
      false;
  
    applyInteractionTool(
      tool,
      false,
    );
  }
  
  function restoreCursorTool() {
    manuallySelectedTool =
      "cursor";
  
    isShiftPanActive =
      false;
  
    applyInteractionTool(
      "cursor",
      false,
    );
  }
  
  interactionToolButtons.forEach(
    (button) => {
      button.addEventListener(
        "click",
        () => {
          const requestedTool =
            button.dataset
              .interactionTool;
  
          if (
            requestedTool !==
              "cursor" &&
            requestedTool !==
              "pan"
          ) {
            return;
          }
  
          selectInteractionTool(
            requestedTool,
          );
        },
      );
    },
  );

  function isTextEntryElement(
    element: Element | null,
  ): boolean {
    return (
      element instanceof
        HTMLInputElement ||
      element instanceof
        HTMLTextAreaElement ||
      element instanceof
        HTMLSelectElement ||
      (
        element instanceof
          HTMLElement &&
        element.isContentEditable
      )
    );
  }
  
  window.addEventListener(
    "keydown",
    (event) => {
      if (
        event.key !== "Shift" ||
        event.repeat ||
        isShiftPanActive
      ) {
        return;
      }
  
      if (
        isTextEntryElement(
          document.activeElement,
        )
      ) {
        return;
      }
  
      isShiftPanActive = true;
  
      applyInteractionTool(
        "pan",
        true,
      );
    },
  );
  
  window.addEventListener(
    "keyup",
    (event) => {
      if (
        event.key !== "Shift" ||
        !isShiftPanActive
      ) {
        return;
      }
  
      isShiftPanActive = false;
  
      applyInteractionTool(
        manuallySelectedTool,
        false,
      );
    },
  );
  
  window.addEventListener(
    "blur",
    () => {
      if (!isShiftPanActive) {
        return;
      }
  
      isShiftPanActive = false;
  
      applyInteractionTool(
        manuallySelectedTool,
        false,
        false,
      );
    },
  );

  /* =======================================================
     FOREST MODE
     ======================================================= */

  function dispatchModeChangedEvent(
    mode: ForestMode,
  ) {
    const detail:
      ForestModeChangedDetail = {
        mode,
      };

    window.dispatchEvent(
      new CustomEvent(
        "forest:mode-changed",
        {
          detail,
        },
      ),
    );
  }

  function animateModeChange() {
    if (
      modeAnimationTimeout !==
      undefined
    ) {
      window.clearTimeout(
        modeAnimationTimeout,
      );
    }

    modeToggleButton?.classList.remove(
      "is-switching",
    );

    modeIndicator?.classList.remove(
      "is-changing",
    );

    /*
      Force the browser to register the removed classes so the
      animation can replay on every toggle.
    */
    void modeToggleButton?.offsetWidth;

    modeToggleButton?.classList.add(
      "is-switching",
    );

    modeIndicator?.classList.add(
      "is-changing",
    );

    modeAnimationTimeout =
      window.setTimeout(
        () => {
          modeToggleButton?.classList.remove(
            "is-switching",
          );

          modeIndicator?.classList.remove(
            "is-changing",
          );
        },
        440,
      );
  }

  function applyForestMode(
    mode: ForestMode,
    animate = true,
  ) {
    currentMode = mode;

    pageBody.dataset.currentMode =
      mode;

    const isPlantingMode =
      mode === "planting";

    if (modeIndicator) {
      modeIndicator.textContent =
        isPlantingMode
          ? "Planting Mode"
          : "Strolling Mode";
    }

    strollModeImage?.classList.toggle(
      "is-visible",
      !isPlantingMode,
    );

    plantModeImage?.classList.toggle(
      "is-visible",
      isPlantingMode,
    );

    if (modeToggleLabel) {
      modeToggleLabel.textContent =
        isPlantingMode
          ? "Switch to Strolling"
          : "Switch to Planting";
    }

    if (modeToggleButton) {
      modeToggleButton.setAttribute(
        "aria-pressed",
        String(isPlantingMode),
      );

      const actionLabel =
        isPlantingMode
          ? "Switch to Strolling Mode"
          : "Switch to Planting Mode";

      modeToggleButton.setAttribute(
        "aria-label",
        actionLabel,
      );

      modeToggleButton.title =
        actionLabel;
    }

    if (patchOperations) {
      patchOperations.setAttribute(
        "aria-hidden",
        String(!isPlantingMode),
      );
    }


    if (animate) {
      animateModeChange();
    }

    dispatchModeChangedEvent(
      mode,
    );

    console.log(
      "Forest mode changed:",
      {
        mode,
      },
    );
  }

  function toggleForestMode() {
    const nextMode:
      ForestMode =
        currentMode === "strolling"
          ? "planting"
          : "strolling";

    closeSearchResults();

    applyForestMode(
      nextMode,
    );
  }

  modeToggleButton?.addEventListener(
    "click",
    toggleForestMode,
  );

  window.addEventListener(
    "forest:request-mode",
    (
      event: Event,
    ) => {
      const customEvent =
        event as CustomEvent<
          ForestModeRequestDetail
        >;
  
      const requestedMode =
        customEvent.detail?.mode;
  
      if (
        requestedMode !==
          "strolling" &&
        requestedMode !==
          "planting"
      ) {
        return;
      }
  
      applyForestMode(
        requestedMode,
        false,
      );
  
      console.log(
        "Forest mode explicitly requested:",
        {
          mode:
            requestedMode,
        },
      );
    },
  );

  /* =======================================================
     HOME BUTTON
     ======================================================= */

  homeButton?.addEventListener(
    "click",
    (
      event,
    ) => {
      event.preventDefault();
      event.stopPropagation();
  
      const childDialogOpen =
        document.querySelector(
          [
            "[data-edit-patch-overlay].is-open",
            "[data-plant-tree-overlay].is-open",
            "[data-edit-tree-overlay].is-open",
            "[data-chop-tree-overlay].is-open",
            "[data-delete-patch-overlay].is-open",
          ].join(", "),
        );
  
      const patchInspectorOpen =
        document.querySelector(
          "[data-patch-viewer-overlay].is-open",
        );
  
      if (
        childDialogOpen ||
        patchInspectorOpen
      ) {
        console.warn(
          "Home action ignored while a Patch Inspector operation is open.",
        );
  
        return;
      }

      window.dispatchEvent(
        new CustomEvent(
          "forest:recenter",
        ),
      );

      closeSearchResults();

      /*
        Home always restores Strolling Mode.
      */
      applyForestMode(
        "strolling",
      );

	  restoreCursorTool();

      console.log(
        "Home button selected.",
      );
    },
  );

  /* =======================================================
     ABOUT BUTTON
     ======================================================= */

  aboutButton?.addEventListener(
    "click",
    () => {
      closeSearchResults();

      window.dispatchEvent(
        new CustomEvent(
          "about-dialog:open",
        ),
      );

      console.log(
        "About dialog requested.",
      );
    },
  );

  /* =======================================================
     PATCH OPERATION PLACEHOLDERS
     ======================================================= */

  addPatchButton?.addEventListener(
    "click",
    () => {
      if (
        currentMode !== "planting"
      ) {
        return;
      }

      closeSearchResults();

      window.dispatchEvent(
        new CustomEvent(
          "add-patch-dialog:open",
        ),
      );

      console.log(
        "Add Patch dialog requested.",
      );
    },
  );

  const deletePatchHint = document.querySelector<HTMLElement>("[data-delete-patch-hint]");
  let deletePatchSelectionActive = false;

  function setDeletePatchSelection(active: boolean) {
    deletePatchSelectionActive = active;
    pageBody.dataset.deletePatchMode = String(active);
    if (deletePatchHint) deletePatchHint.hidden = !active;
    window.dispatchEvent(new CustomEvent("forest:delete-patch-selection", { detail: { active } }));
  }

  deletePatchButton?.addEventListener("click", () => {
    if (currentMode !== "planting") return;
    closeSearchResults();
    setDeletePatchSelection(true);
  });

  window.addEventListener("forest:delete-patch-selection", (event: Event) => {
    const active = Boolean((event as CustomEvent<{active?: boolean}>).detail?.active);
    deletePatchSelectionActive = active;
    pageBody.dataset.deletePatchMode = String(active);
    if (deletePatchHint) deletePatchHint.hidden = !active;
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && deletePatchSelectionActive) {
      event.preventDefault();
      event.stopImmediatePropagation();
      setDeletePatchSelection(false);
    }
  }, true);

  /* =======================================================
     TREE SEARCH HELPERS
     ======================================================= */

  function normalizeSearchText(
    value: string,
  ): string {
    return value
      .trim()
      .toLocaleLowerCase();
  }

  function setSearchExpanded(
    expanded: boolean,
  ) {
    searchInput?.setAttribute(
      "aria-expanded",
      String(expanded),
    );
  }

  function resetActiveResult() {
    activeResultIndex = -1;

    searchResults.forEach(
      (result) => {
        result.classList.remove(
          "is-active",
        );

        result.setAttribute(
          "aria-selected",
          "false",
        );
      },
    );
  }

  function setActiveResult(
    newIndex: number,
  ) {
    if (
      visibleResults.length === 0
    ) {
      resetActiveResult();
      return;
    }

    const normalizedIndex =
      ((newIndex %
        visibleResults.length) +
        visibleResults.length) %
      visibleResults.length;

    resetActiveResult();

    activeResultIndex =
      normalizedIndex;

    const activeResult =
      visibleResults[
        activeResultIndex
      ];

    activeResult.classList.add(
      "is-active",
    );

    activeResult.setAttribute(
      "aria-selected",
      "true",
    );

    activeResult.scrollIntoView({
      block: "nearest",
    });
  }

  function closeSearchResults() {
    if (resultsPanel) {
      resultsPanel.hidden = true;
    }

    setSearchExpanded(false);
    resetActiveResult();
  }

  function openSearchResults() {
    if (!resultsPanel) return;

    resultsPanel.hidden = false;

    setSearchExpanded(true);
  }

  function updateClearButton() {
    if (!clearSearchButton) {
      return;
    }

    clearSearchButton.hidden =
      !searchInput?.value;
  }

  function updateSearchResults() {
    if (
      !searchInput ||
      !resultsPanel
    ) {
      return;
    }

    const query =
      normalizeSearchText(
        searchInput.value,
      );

    visibleResults = [];

    for (
      const result of searchResults
    ) {
      const treeName =
        result.dataset
          .normalizedTreeName ??
        "";

      const patchName =
        result.dataset
          .normalizedPatchName ??
        "";

      const isMatch =
        query.length > 0 &&
        (
          treeName.includes(query) ||
          patchName.includes(query)
        );

      result.hidden = !isMatch;

      if (isMatch) {
        visibleResults.push(
          result,
        );
      }
    }

    const hasQuery =
      query.length > 0;

    const hasResults =
      visibleResults.length > 0;

    if (emptySearchMessage) {
      emptySearchMessage.hidden =
        !hasQuery ||
        hasResults;
    }

    if (hasQuery) {
      openSearchResults();
    } else {
      closeSearchResults();
    }

    resetActiveResult();
    updateClearButton();

    console.log(
      "Tree search updated:",
      {
        query,
        resultCount:
          visibleResults.length,
      },
    );
  }

  function chooseSearchResult(
    result: HTMLButtonElement,
  ) {
    const patchId =
      result.dataset.patchId?.trim();

    const treeId =
      result.dataset.treeId?.trim();

    if (
      !patchId ||
      !treeId
    ) {
      console.warn(
        "The selected tree search result is missing its patch or tree ID.",
      );

      return;
    }

    const detail:
      PatchViewerOpenDetail = {
        patchId,
        treeId,
      };

    window.dispatchEvent(
      new CustomEvent(
        "patch-viewer:open",
        {
          detail,
        },
      ),
    );

    if (searchInput) {
      searchInput.value =
        result.dataset.treeName ??
        "";
    }

    updateClearButton();
    closeSearchResults();

    console.log(
      "Tree search result selected:",
      {
        patchId,
        treeId,
        treeName:
          result.dataset.treeName,
        patchName:
          result.dataset.patchName,
      },
    );
  }

  function connectSearchResult(
    result: HTMLButtonElement,
  ) {
    result.addEventListener(
      "click",
      () => {
        chooseSearchResult(
          result,
        );
      },
    );

    result.addEventListener(
      "mouseenter",
      () => {
        const index =
          visibleResults.indexOf(
            result,
          );

        if (index >= 0) {
          setActiveResult(
            index,
          );
        }
      },
    );
  }

  function addTreeSearchResult(
    tree: TreeRecord,
    patch: ForestPatchRecord,
  ) {
    if (!resultsPanel) {
      return;
    }

    const result =
      document.createElement(
        "button",
      );

    result.className =
      "tree-search-result";

    result.type =
      "button";

    result.setAttribute(
      "role",
      "option",
    );

    result.dataset.treeSearchResult =
      "";

    result.dataset.treeId =
      tree.Tree_ID;

    result.dataset.treeName =
      tree.Tree_Name;

    result.dataset.patchId =
      patch.Patch_ID;

    result.dataset.patchName =
      patch.Patch_Name;

    result.dataset.normalizedTreeName =
      normalizeSearchText(
        tree.Tree_Name,
      );

    result.dataset.normalizedPatchName =
      normalizeSearchText(
        patch.Patch_Name,
      );

    result.hidden =
      true;

    const treeNameElement =
      document.createElement(
        "span",
      );

    treeNameElement.className =
      "search-result-tree-name";

    treeNameElement.textContent =
      tree.Tree_Name;

    const patchNameElement =
      document.createElement(
        "span",
      );

    patchNameElement.className =
      "search-result-patch-name";

    patchNameElement.textContent =
      patch.Patch_Name;

    result.append(
      treeNameElement,
      patchNameElement,
    );

    resultsPanel.insertBefore(
      result,
      emptySearchMessage ??
      null,
    );

    searchResults.push(
      result,
    );

    connectSearchResult(
      result,
    );

    console.log(
      "Tree search result added:",
      {
        treeId:
          tree.Tree_ID,
        patchId:
          patch.Patch_ID,
      },
    );
  }

  /* =======================================================
     TREE SEARCH EVENTS
     ======================================================= */

  searchInput?.addEventListener(
    "input",
    updateSearchResults,
  );

  searchInput?.addEventListener(
    "focus",
    () => {
      if (
        searchInput.value.trim()
      ) {
        updateSearchResults();
      }
    },
  );

  searchInput?.addEventListener(
    "keydown",
    (event) => {
      if (
        event.key ===
        "ArrowDown"
      ) {
        event.preventDefault();

        if (
          resultsPanel?.hidden
        ) {
          updateSearchResults();
        }

        setActiveResult(
          activeResultIndex + 1,
        );

        return;
      }

      if (
        event.key ===
        "ArrowUp"
      ) {
        event.preventDefault();

        setActiveResult(
          activeResultIndex - 1,
        );

        return;
      }

      if (
        event.key === "Enter"
      ) {
        if (
          activeResultIndex >= 0 &&
          visibleResults[
            activeResultIndex
          ]
        ) {
          event.preventDefault();

          chooseSearchResult(
            visibleResults[
              activeResultIndex
            ],
          );
        } else if (
          visibleResults.length === 1
        ) {
          event.preventDefault();

          chooseSearchResult(
            visibleResults[0],
          );
        }

        return;
      }

      if (
        event.key === "Escape"
      ) {
        closeSearchResults();
      }
    },
  );

  clearSearchButton?.addEventListener(
    "click",
    () => {
      if (!searchInput) return;

      searchInput.value = "";

      updateSearchResults();

      searchInput.focus();

      console.log(
        "Tree search cleared.",
      );
    },
  );

  searchResults.forEach(
    connectSearchResult,
  );

  document.addEventListener(
    "pointerdown",
    (event) => {
      const target =
        event.target as Node;

      if (
        searchContainer &&
        !searchContainer.contains(
          target,
        )
      ) {
        closeSearchResults();
      }
    },
  );

  window.addEventListener(
    "forest:state-changed",
    (
      event: Event,
    ) => {
      const customEvent =
        event as CustomEvent<
          ForestStateChangedDetail
        >;

      const statistics =
        customEvent.detail
          ?.snapshot
          .statistics;

      if (!statistics) {
        return;
      }

      if (
        customEvent.detail
          ?.reason ===
        "tree-added"
      ) {
        const snapshot =
          customEvent.detail
            .snapshot;

        const newestTree =
          snapshot.trees[
            snapshot.trees.length - 1
          ];

        const parentPatch =
          newestTree
            ? snapshot.patches.find(
                (patch) =>
                  patch.Patch_ID ===
                  newestTree.Patch_ID,
              )
            : undefined;

        if (
          newestTree &&
          parentPatch &&
          !searchResults.some(
            (result) =>
              result.dataset.treeId ===
              newestTree.Tree_ID,
          )
        ) {
          addTreeSearchResult(
            newestTree,
            parentPatch,
          );
        }
      }

      if (
        customEvent.detail
          ?.reason ===
        "patch-updated"
      ) {
        const patches =
          customEvent.detail
            .snapshot
            .patches;

        for (
          const result of
          searchResults
        ) {
          const patchId =
            result.dataset
              .patchId;

          const updatedPatch =
            patches.find(
              (patch) =>
                patch.Patch_ID ===
                patchId,
            );

          if (!updatedPatch) {
            continue;
          }

          result.dataset.patchName =
            updatedPatch.Patch_Name;

          result.dataset
            .normalizedPatchName =
            normalizeSearchText(
              updatedPatch.Patch_Name,
            );

          const patchNameElement =
            result.querySelector<HTMLElement>(
              ".search-result-patch-name",
            );

          if (patchNameElement) {
            patchNameElement.textContent =
              updatedPatch.Patch_Name;
          }
        }

        if (
          searchInput?.value.trim()
        ) {
          updateSearchResults();
        }
      }

      if (customEvent.detail?.reason === "tree-updated") {
        const trees = customEvent.detail.snapshot.trees;
        for (const result of searchResults) {
          const tree = trees.find((record) => record.Tree_ID === result.dataset.treeId);
          if (!tree) continue;
          result.dataset.treeName = tree.Tree_Name;
          result.dataset.normalizedTreeName = normalizeSearchText(tree.Tree_Name);
          const nameElement = result.querySelector<HTMLElement>(".search-result-tree-name");
          if (nameElement) nameElement.textContent = tree.Tree_Name;
        }
      }

      if (customEvent.detail?.reason === "tree-deleted" || customEvent.detail?.reason === "patch-deleted") {
        const validTreeIds = new Set(customEvent.detail.snapshot.trees.map((tree) => tree.Tree_ID));
        searchResults = searchResults.filter((result) => {
          const keep = validTreeIds.has(result.dataset.treeId ?? "");
          if (!keep) result.remove();
          return keep;
        });
        closeSearchResults();
      }

      if (patchCountElement) {
        patchCountElement.textContent =
          String(
            statistics.patchCount,
          );
      }

      if (saplingCountElement) {
        saplingCountElement.textContent =
          String(
            statistics.saplingCount,
          );
      }

      if (treeCountElement) {
        treeCountElement.textContent =
          String(
            statistics.treeCount,
          );
      }

      console.log(
        "Header statistics updated:",
        statistics,
      );
    },
  );

  window.addEventListener(
    "forest:tree-added",
    (
      event: Event,
    ) => {
      const customEvent =
        event as CustomEvent<{
          tree?: TreeRecord;
          patch?: ForestPatchRecord;
        }>;

      const tree =
        customEvent.detail
          ?.tree;

      const patch =
        customEvent.detail
          ?.patch;

      if (
        !tree ||
        !patch ||
        searchResults.some(
          (result) =>
            result.dataset.treeId ===
            tree.Tree_ID,
        )
      ) {
        return;
      }

      addTreeSearchResult(
        tree,
        patch,
      );
    },
  );

  /* =======================================================
     INITIAL STATE
     ======================================================= */

  const initialPatches =
    parseInitialData<
      ForestPatchRecord[]
    >(
      initialPatchesData,
      [],
    );

  const initialTrees =
    parseInitialData<
      TreeRecord[]
    >(
      initialTreesData,
      [],
    );

  if (
    !isForestStateInitialized()
  ) {
    initializeForestState(
      initialPatches,
      initialTrees,
    );
  }

  applyForestMode(
    "strolling",
    false,
  );

  updateClearButton();
</script>