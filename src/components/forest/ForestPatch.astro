---
import SkillTree from "./SkillTree.astro";
import type { TreeRecord } from "../../scripts/loadForestData";

interface Props {
  patchName: string;
  patchStyle: string;
  x: number;
  y: number;
  trees?: TreeRecord[];
  scale?: number;
  showLabel?: boolean;
  patchId: string;
  patchDescription: string;
  saplingsPlanted: number;
  treesGrown: number;
}

const {
  patchId,
  patchName,
  patchStyle,
  patchDescription,
  saplingsPlanted,
  treesGrown,
  x,
  y,
  trees = [],
  scale = 0.40,
  showLabel = true,
} = Astro.props;

const normalizedStyle = patchStyle.padStart(2, "0");
const groundPath = `/assets/grounds/Ground_${normalizedStyle}.png`;

const nativePatchSize = 945;
const displaySize = nativePatchSize * scale;
---

<div
  class="forest-patch"
  role="button"
  tabindex="0"
  data-patch-viewer-trigger
  data-patch-id={patchId}
  data-patch-name={patchName}
  data-patch-style={normalizedStyle}
  data-patch-description={patchDescription}
  data-patch-saplings={saplingsPlanted}
  data-patch-trees={treesGrown}
  style={`
    left: ${x}px;
    top: ${y}px;
    width: ${displaySize}px;
    height: ${displaySize}px;
  `}
>
  <img
    src={groundPath}
    alt={patchName}
    class="ground-patch"
    draggable="false"
  />

  {
    trees.map((tree) => (
      <SkillTree
        treeId={tree.Tree_ID}
        treeName={tree.Tree_Name}
        treeDescription={tree.Tree_Description}
        datePlanted={tree.Date_Planted}
        dateSprouted={tree.Date_Sprouted}
        evidencePath={tree.Evidence_Path}
        patchStyle={patchStyle}
        growthStage={tree.Growth_Stage}
        displaySlot={tree.Display_Slot}
        patchScale={scale}
      />
    ))
  }

  {
    showLabel && (
      <div class="patch-label">
        {patchName}
      </div>
    )
  }

  {
    showLabel && (
      <div class="patch-description">
        {
          patchDescription ||
          "No patch description has been provided."
        }
      </div>
    )
  } 
</div>

<style>
  .forest-patch {
    position: absolute;
    transform: translate(-50%, -50%);
    user-select: none;
  }

  .ground-patch {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    pointer-events: none;
  }

  .patch-label {
    position: absolute;
    left: 50%;
    top: 8%;
    z-index: 1000;

    transform: translate(-50%, 6px);
    padding: 6px 10px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.88);
    font-weight: 700;
    white-space: nowrap;
    pointer-events: none;

    opacity: 0;
    visibility: hidden;
    transition:
      opacity 180ms ease,
      transform 180ms ease,
      visibility 180ms ease;
  }

  .patch-description {
    position: absolute;
    left: 50%;
    bottom: 5%;
    z-index: 1001;

    width: min(88%, 340px);
    padding: 10px 14px;

    transform: translate(-50%, 8px);

    border: 1px solid rgba(40, 127, 177, 0.55);
    border-radius: 10px;

    background:
      linear-gradient(
        135deg,
        rgba(232, 250, 255, 0.96),
        rgba(190, 228, 248, 0.96)
      );

    box-shadow:
      0 7px 18px rgba(26, 92, 133, 0.20);

    color: #103b54;
    font-size: 13px;
    font-weight: 600;
    line-height: 1.35;
    text-align: center;

    opacity: 0;
    visibility: hidden;
    pointer-events: none;

    transition:
      opacity 180ms ease,
      transform 180ms ease,
      visibility 180ms ease;
  }

  .forest-patch:hover .patch-description,
  .forest-patch:focus-visible .patch-description {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, 0);
  }

  .forest-patch:hover .patch-label {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, 0);
  }

  .ground-patch {
    transition:
      transform 180ms ease,
      filter 180ms ease;
  }

  .forest-patch:hover .ground-patch {
    transform: scale(1.02);
    filter: brightness(1.06);
  }
  .forest-patch {
    cursor: pointer;
  }

  .forest-patch:focus-visible {
    outline: 4px solid rgba(99, 200, 255, 0.9);
    outline-offset: 5px;
  }
</style>