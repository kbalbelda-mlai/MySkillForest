---
interface Props {
  dialogId?: string;
}

const {
  dialogId = "patch-viewer-dialog",
} = Astro.props;

const isOwnerMode = import.meta.env.DEV;
---

<div
  id={dialogId}
  class="patch-viewer-overlay"
  aria-hidden="true"
  data-patch-viewer-overlay
>
  <section
    class="patch-viewer-dialog"
    role="dialog"
    aria-modal="true"
    aria-labelledby="patch-viewer-title"
  >
    <button
      class="close-button"
      type="button"
      aria-label="Close forest patch viewer"
      data-close-patch-viewer
    >
      ×
    </button>

    <div class="patch-preview-panel">
      <div
        class="patch-preview-canvas"
        data-patch-preview-canvas
      ></div>

      <div
        class="patch-inspector-actions"
        data-owner-only={String(isOwnerMode)}
        role="toolbar"
        aria-label="Patch inspector actions"
        aria-hidden="true"
        data-patch-inspector-actions
      >
        <button
          class="patch-inspector-action"
          type="button"
          aria-label="Edit Patch"
          title="Edit Patch"
          data-tooltip="Edit Patch"
          data-patch-action="edit-patch"
        >
          <img
            src="/assets/ui/Button_Edit_Patch.png"
            alt=""
            aria-hidden="true"
            draggable="false"
          />
        </button>

        <button
          class="patch-inspector-action"
          type="button"
          aria-label="Plant a Tree"
          title="Plant a Tree"
          data-tooltip="Plant a Tree"
          data-patch-action="plant-tree"
        >
          <img
            src="/assets/ui/Button_Plant_Tree.png"
            alt=""
            aria-hidden="true"
            draggable="false"
          />
        </button>

        <button
          class="patch-inspector-action"
          type="button"
          aria-label="Edit a Tree"
          title="Edit a Tree"
          data-tooltip="Edit a Tree"
          data-patch-action="edit-tree"
          disabled
        >
          <img
            src="/assets/ui/Button_Edit_Tree.png"
            alt=""
            aria-hidden="true"
            draggable="false"
          />
        </button>

        <button
          class="patch-inspector-action danger"
          type="button"
          aria-label="Chop a Tree"
          title="Chop a Tree"
          data-tooltip="Chop a Tree"
          data-patch-action="chop-tree"
          disabled
        >
          <img
            src="/assets/ui/Button_Chop_Tree.png"
            alt=""
            aria-hidden="true"
            draggable="false"
          />
        </button>
      </div>
    </div>

    <div class="patch-information-panel">
      <h2 id="patch-viewer-title">
        Forest Patch Name
      </h2>

      <div class="patch-counts">
        <p>
          <strong>Saplings:</strong>
          <span data-patch-saplings>0</span>
        </p>

        <p>
          <strong>Trees:</strong>
          <span data-patch-trees>0</span>
        </p>
      </div>

      <div class="tree-information">
        <h3 data-tree-name>
          Select a tree
        </h3>

        <p>
          <strong>Planted on:</strong>
          <span data-tree-planted>
            Not Specified
          </span>
        </p>

        <p>
          <strong>Sprouted on:</strong>
          <span data-tree-sprouted>
            Not Specified
          </span>
        </p>

        <p
          data-tree-evidence-row
          hidden
        >
          <strong>Evidence:</strong>
        
          <a
            data-tree-link
            href=""
            target="_blank"
            rel="noopener noreferrer"
            hidden
          >
            Open evidence
          </a>
        
          <span data-tree-link-empty>
            Not Available
          </span>
        </p>

        <div class="tree-description">
          <strong>Tree description</strong>

          <p data-tree-description>
            Select a tree from the forest patch to view its information.
          </p>
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  /* =======================================================
     OVERLAY
     ======================================================= */

  .patch-viewer-overlay {
    position: fixed;
    inset: 0;
    z-index: 5000;

    display: grid;
    place-items: center;

    padding: 40px;

    background:
      rgba(5, 38, 52, 0.82);

    backdrop-filter: blur(4px);

    opacity: 0;
    visibility: hidden;
    pointer-events: none;

    transition:
      opacity 220ms ease,
      visibility 220ms ease;
  }

  .patch-viewer-overlay.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  /* =======================================================
     DIALOG
     ======================================================= */

  .patch-viewer-dialog {
    position: relative;

    display: grid;
    grid-template-columns:
      minmax(420px, 1.1fr)
      minmax(340px, 0.9fr);

    gap: 48px;

    width: min(1180px, 92vw);
    height: min(650px, 84vh);

    padding: 34px;

    background:
      rgba(255, 255, 255, 0.97);

    border-radius: 28px;

    box-shadow:
      0 24px 70px
      rgba(0, 0, 0, 0.35);

    transform:
      translateY(18px)
      scale(0.97);

    transition:
      transform 220ms ease;
  }

  .patch-viewer-overlay.is-open
  .patch-viewer-dialog {
    transform:
      translateY(0)
      scale(1);
  }

  /* =======================================================
     CLOSE BUTTON
     ======================================================= */

  .close-button {
    position: absolute;
    top: -28px;
    right: -28px;
    z-index: 20;

    width: 82px;
    height: 82px;

    border:
      2px solid #082b3a;

    border-radius: 50%;

    background: #176887;
    color: white;

    font-size: 54px;
    font-weight: 300;
    line-height: 1;

    cursor: pointer;

    transition:
      transform 160ms ease,
      background 160ms ease;
  }

  .close-button:hover {
    transform: scale(1.06);
    background: #1d789b;
  }

  .close-button:focus-visible {
    outline:
      4px solid
      rgba(104, 209, 255, 0.9);

    outline-offset: 4px;
  }

  /* =======================================================
     PATCH PREVIEW
     ======================================================= */

  .patch-preview-panel {
    position: relative;
    min-width: 0;
    min-height: 0;

    display: grid;
    place-items: center;

    overflow: visible;

    border:
      3px solid #0a2d3d;

    border-radius: 26px;

    background: #eaf5f8;
  }

  .patch-preview-canvas {
    position: relative;

    width: min(500px, 86%);

    aspect-ratio: 1;

    overflow: visible;
  }

  .patch-preview-canvas
  :global(.forest-patch) {
    left: 50% !important;
    top: 52% !important;

    cursor: default;

    transform:
      translate(-50%, -50%)
      scale(1.12);
  }

  .patch-preview-canvas
  :global(.patch-label) {
    display: none;
  }

  .patch-preview-canvas
  :global(.ground-patch) {
    transform: none;
    filter: none;
    pointer-events: none;
  }

  .patch-preview-canvas
  :global(
    .forest-patch:hover
    .ground-patch
  ) {
    transform: none !important;
    filter: none !important;
  }

  /* =======================================================
     PATCH INSPECTOR ACTIONS
     ======================================================= */

  .patch-inspector-actions {
    position: absolute;
    right: 18px;
    bottom: 18px;
    z-index: 7200;

    display: flex;
    align-items: center;

    gap: 9px;

    padding: 8px;

    border:
      1px solid
      rgba(24, 80, 102, 0.24);

    border-radius: 14px;

    background:
      rgba(255, 255, 255, 0.94);

    box-shadow:
      0 10px 24px
      rgba(16, 65, 84, 0.22);

    opacity: 0;
    visibility: hidden;

    transform:
      translateY(10px)
      scale(0.96);

    pointer-events: none;

    transition:
      opacity 180ms ease,
      visibility 180ms ease,
      transform 220ms
      cubic-bezier(
        0.34,
        1.56,
        0.64,
        1
      );

    backdrop-filter: blur(7px);
  }

  .patch-inspector-actions[data-owner-only="false"] {
    display: none !important;
  }

  .patch-viewer-overlay.is-planting-mode
  .patch-inspector-actions {
    opacity: 1;
    visibility: visible;

    transform:
      translateY(0)
      scale(1);

    pointer-events: auto;
  }

  .patch-inspector-action {
    position: relative;

    width: 50px;
    height: 50px;

    display: grid;
    place-items: center;

    padding: 4px;

    border:
      2px solid
      rgba(41, 114, 143, 0.28);

    border-radius: 11px;

    background:
      rgba(238, 249, 253, 0.98);

    box-shadow:
      0 4px 10px
      rgba(21, 75, 96, 0.12);

    cursor: pointer;

    transition:
      transform 150ms ease,
      border-color 150ms ease,
      background 150ms ease,
      box-shadow 150ms ease,
      opacity 150ms ease,
      filter 150ms ease;
  }

  .patch-inspector-action img {
    width: 100%;
    height: 100%;

    display: block;

    object-fit: contain;

    border-radius: 7px;

    pointer-events: none;

    user-select: none;
    -webkit-user-drag: none;
  }

  .patch-inspector-action:hover:not(:disabled) {
    border-color:
      rgba(38, 143, 188, 0.82);

    background:
      rgba(221, 245, 255, 1);

    box-shadow:
      0 0 0 4px
      rgba(57, 169, 217, 0.14),
      0 8px 17px
      rgba(21, 90, 120, 0.20);

    transform:
      translateY(-2px)
      scale(1.04);
  }

  .patch-inspector-action:active:not(:disabled) {
    transform:
      translateY(1px)
      scale(0.88);
  }

  .patch-inspector-action:focus-visible {
    outline:
      3px solid
      rgba(61, 177, 224, 0.82);

    outline-offset: 3px;
  }

  .patch-inspector-action.is-activating {
    animation:
      patch-action-activated
      360ms
      cubic-bezier(
        0.34,
        1.56,
        0.64,
        1
      );
  }

  .patch-inspector-action:disabled {
    opacity: 0.34;

    filter:
      grayscale(0.88)
      saturate(0.30);

    cursor: not-allowed;

    box-shadow: none;

    transform: none;
  }

  .patch-inspector-action:disabled::after {
    display: none;
  }

  .patch-inspector-action::after {
    position: absolute;
    left: 50%;
    bottom: calc(100% + 10px);
    z-index: 7400;

    width: max-content;
    max-width: 190px;

    padding:
      7px 10px;

    border:
      1px solid
      rgba(30, 87, 108, 0.20);

    border-radius: 8px;

    background:
      rgba(255, 255, 255, 0.98);

    box-shadow:
      0 7px 17px
      rgba(15, 63, 81, 0.18);

    color: #214b5c;

    content:
      attr(data-tooltip);

    font-size: 12px;
    font-weight: 700;
    line-height: 1.25;

    white-space: nowrap;

    opacity: 0;
    visibility: hidden;

    pointer-events: none;

    transform:
      translate(-50%, 5px);

    transition:
      opacity 140ms ease,
      visibility 140ms ease,
      transform 140ms ease;
  }

  .patch-inspector-action:hover::after,
  .patch-inspector-action:focus-visible::after {
    opacity: 1;
    visibility: visible;

    transform:
      translate(-50%, 0);
  }

  @keyframes patch-action-activated {
    0% {
      transform: scale(1);
    }

    42% {
      transform:
        scale(0.80)
        rotate(-6deg);
    }

    72% {
      transform:
        scale(1.12)
        rotate(4deg);
    }

    100% {
      transform: scale(1);
    }
  }

  /* =======================================================
     PATCH DESCRIPTION
     ======================================================= */

  .patch-description-bubble {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 6000;

    width: 100%;

    padding:
      16px 22px;

    border-top:
      1px solid
      rgba(40, 127, 177, 0.4);

    background:
      linear-gradient(
        135deg,
        rgba(232, 250, 255, 0.97),
        rgba(190, 228, 248, 0.97)
      );

    box-shadow:
      0 -8px 24px
      rgba(20, 77, 108, 0.16);

    color: #103b54;

    font-size: 15px;
    font-weight: 600;
    line-height: 1.45;

    text-align: center;

    opacity: 0;
    visibility: hidden;

    transform:
      translateY(100%);

    pointer-events: none;

    transition:
      opacity 180ms ease,
      visibility 180ms ease,
      transform 180ms ease;
  }

  .patch-preview-panel:hover
  .patch-description-bubble,
  .patch-preview-panel:focus-within
  .patch-description-bubble {
    opacity: 1;
    visibility: visible;

    transform:
      translateY(0);
  }

  /* =======================================================
     INTERACTIVE TREES
     ======================================================= */

  .patch-preview-canvas
  :global(.skill-tree) {
    cursor: pointer;
    pointer-events: auto;

    transition:
      transform 180ms ease,
      filter 180ms ease;
  }

  .patch-preview-canvas
  :global(.skill-tree img) {
    pointer-events: none;
  }

  .patch-preview-canvas
  :global(.skill-tree:hover),
  .patch-preview-canvas
  :global(.skill-tree.is-selected) {
    filter:
      drop-shadow(
        0 0 2px
        rgba(219, 248, 255, 1)
      )
      drop-shadow(
        0 0 6px
        rgba(93, 211, 255, 0.95)
      )
      drop-shadow(
        0 0 12px
        rgba(56, 128, 255, 0.78)
      );

    animation:
      tree-blue-glow
      1.4s ease-in-out
      infinite alternate;
  }

  .patch-preview-canvas
  :global(.skill-tree:hover) {
    transform:
      translate(-50%, -100%)
      translateY(-4px)
      scale(1.045);
  }

  .patch-preview-canvas
  :global(.skill-tree.is-selected) {
    transform:
      translate(-50%, -100%)
      scale(1.025);
  }

  .patch-preview-canvas
  :global(.skill-tree:focus-visible) {
    outline: none;

    filter:
      drop-shadow(
        0 0 3px
        rgba(232, 252, 255, 1)
      )
      drop-shadow(
        0 0 9px
        rgba(93, 211, 255, 1)
      )
      drop-shadow(
        0 0 16px
        rgba(56, 128, 255, 0.9)
      );
  }

  /* =======================================================
     TREE HOVER LABEL
     ======================================================= */

  .patch-preview-canvas
  :global(.skill-tree::after) {
    content:
      attr(data-tree-name);

    position: absolute;
    left: 50%;
    bottom:
      calc(100% + 8px);

    z-index: 7000;

    transform:
      translate(-50%, 6px);

    padding:
      6px 10px;

    border:
      1px solid
      rgba(40, 127, 177, 0.65);

    border-radius: 8px;

    background:
      linear-gradient(
        135deg,
        rgba(232, 250, 255, 0.98),
        rgba(185, 225, 255, 0.98)
      );

    box-shadow:
      0 5px 15px
      rgba(26, 92, 133, 0.24);

    color: #103b54;

    font-size: 12px;
    font-weight: 700;
    line-height: 1.2;

    white-space: nowrap;

    opacity: 0;
    visibility: hidden;

    pointer-events: none;

    transition:
      opacity 150ms ease,
      transform 150ms ease,
      visibility 150ms ease;
  }

  .patch-preview-canvas
  :global(
    .skill-tree:hover::after
  ),
  .patch-preview-canvas
  :global(
    .skill-tree.is-selected::after
  ),
  .patch-preview-canvas
  :global(
    .skill-tree:focus-visible::after
  ) {
    opacity: 1;
    visibility: visible;

    transform:
      translate(-50%, 0);
  }

  @keyframes tree-blue-glow {
    from {
      filter:
        drop-shadow(
          0 0 2px
          rgba(219, 248, 255, 0.9)
        )
        drop-shadow(
          0 0 5px
          rgba(93, 211, 255, 0.75)
        )
        drop-shadow(
          0 0 9px
          rgba(56, 128, 255, 0.6)
        );
    }

    to {
      filter:
        drop-shadow(
          0 0 3px
          rgba(232, 252, 255, 1)
        )
        drop-shadow(
          0 0 8px
          rgba(93, 211, 255, 1)
        )
        drop-shadow(
          0 0 16px
          rgba(56, 128, 255, 0.88)
        );
    }
  }

  /* =======================================================
     INFORMATION PANEL
     ======================================================= */

  .patch-information-panel {
    min-width: 0;

    overflow-y: auto;

    padding:
      10px 8px 10px 0;
  }

  .patch-information-panel h2 {
    margin:
      0 0 24px;

    max-width: 100%;

    font-size:
      clamp(26px, 3vw, 42px);

    line-height: 1.08;

    overflow-wrap: anywhere;
    word-break: normal;
    text-wrap: balance;
  }

  .patch-counts {
    display: flex;
    flex-wrap: wrap;

    gap:
      12px 56px;

    margin-bottom: 42px;

    font-size: 20px;
  }

  .patch-counts p {
    margin: 0;
  }

  .patch-counts strong,
  .tree-information > p strong {
    margin-right: 0.3rem;
  }

  .tree-information h3 {
    margin:
      0 0 26px;

    font-size: 25px;

    overflow-wrap: anywhere;
  }

  .tree-information > p {
    margin:
      0 0 20px;

    font-size: 18px;
  }

  .tree-information a {
    color: #176887;
    font-weight: 700;
  }

  .tree-description {
    margin-top: 42px;

    font-size: 18px;
  }

  .tree-description p {
    margin-top: 12px;

    line-height: 1.55;
    overflow-wrap: anywhere;
  }

  /* =======================================================
     RESPONSIVE VIEW
     ======================================================= */

  @media (max-width: 850px) {
    .patch-viewer-overlay {
      padding: 22px;
    }

    .patch-viewer-dialog {
      grid-template-columns: 1fr;

      grid-template-rows:
        minmax(280px, 1fr)
        auto;

      width: 94vw;
      height: 90vh;

      gap: 24px;
      padding: 24px;

      overflow-y: auto;
    }

    .close-button {
      top: -14px;
      right: -10px;

      width: 58px;
      height: 58px;

      font-size: 38px;
    }

    .patch-preview-panel {
      min-height: 340px;
    }

    .patch-preview-canvas {
      width:
        min(460px, 92%);
    }

    .patch-preview-canvas
    :global(.patch-description) {
      display: none !important;
    }

    .patch-information-panel {
      overflow: visible;
    }
  }
</style>

<script>
  /* =======================================================
     TYPES
     ======================================================= */

  type ForestMode =
    | "strolling"
    | "planting";

  type PatchInspectorAction =
    | "edit-patch"
    | "plant-tree"
    | "edit-tree"
    | "chop-tree";

  interface OpenPatchViewerDetail {
    patchId: string;
    treeId?: string;
  }

  interface ForestModeChangedDetail {
    mode: ForestMode;
  }

  interface PatchInspectorActionDetail {
    action: PatchInspectorAction;
    patchId: string;
    treeId?: string;
  }

  /* =======================================================
     ELEMENT REFERENCES
     ======================================================= */

  const overlay =
    document.querySelector<HTMLElement>(
      "#patch-viewer-dialog",
    );

  const closeButton =
    overlay?.querySelector<HTMLButtonElement>(
      "[data-close-patch-viewer]",
    );

  const title =
    overlay?.querySelector<HTMLElement>(
      "#patch-viewer-title",
    );

  const saplingCount =
    overlay?.querySelector<HTMLElement>(
      "[data-patch-saplings]",
    );

  const treeCount =
    overlay?.querySelector<HTMLElement>(
      "[data-patch-trees]",
    );

  const previewCanvas =
    overlay?.querySelector<HTMLElement>(
      "[data-patch-preview-canvas]",
    );

  const patchInspectorActions =
    overlay?.querySelector<HTMLElement>(
      "[data-patch-inspector-actions]",
    );

  const patchActionButtons =
    Array.from(
      overlay?.querySelectorAll<HTMLButtonElement>(
        "[data-patch-action]",
      ) ?? [],
    );

  const editPatchActionButton =
    overlay?.querySelector<HTMLButtonElement>(
      '[data-patch-action="edit-patch"]',
    );

  const plantTreeActionButton =
    overlay?.querySelector<HTMLButtonElement>(
      '[data-patch-action="plant-tree"]',
    );

  const editTreeActionButton =
    overlay?.querySelector<HTMLButtonElement>(
      '[data-patch-action="edit-tree"]',
    );

  const chopTreeActionButton =
    overlay?.querySelector<HTMLButtonElement>(
      '[data-patch-action="chop-tree"]',
    );

  const treeName =
    overlay?.querySelector<HTMLElement>(
      "[data-tree-name]",
    );

  const treePlanted =
    overlay?.querySelector<HTMLElement>(
      "[data-tree-planted]",
    );

  const treeSprouted =
    overlay?.querySelector<HTMLElement>(
      "[data-tree-sprouted]",
    );

  const treeDescription =
    overlay?.querySelector<HTMLElement>(
      "[data-tree-description]",
    );

  const treeLink =
    overlay?.querySelector<HTMLAnchorElement>(
      "[data-tree-link]",
    );

  const treeLinkEmpty =
    overlay?.querySelector<HTMLElement>(
      "[data-tree-link-empty]",
    );

  const treeEvidenceRow =
    overlay?.querySelector<HTMLElement>(
      "[data-tree-evidence-row]",
    );

  let previouslyFocusedElement:
    HTMLElement | null = null;

  const baseUrl = import.meta.env.BASE_URL;
  const isOwnerMode = document.body.dataset.ownerMode === "true";

  let currentForestMode:
    ForestMode =
      document.body.dataset
        .currentMode === "planting"
        ? "planting"
        : "strolling";

  let activePatchId:
    string | null = null;

  let selectedTreeId:
    string | null = null;

  let patchActionAnimationTimeout:
    number | undefined;

  /* =======================================================
     PATCH INSPECTOR ACTIONS
     ======================================================= */

  function updatePatchInspectorMode(
    mode: ForestMode,
  ) {
    currentForestMode = mode;

    const isPlantingMode =
      isOwnerMode && mode === "planting";

    overlay?.classList.toggle(
      "is-planting-mode",
      isPlantingMode,
    );

    patchInspectorActions?.setAttribute(
      "aria-hidden",
      String(!isPlantingMode),
    );

    updatePatchActionAvailability();

    console.log(
      "Patch Inspector mode updated:",
      {
        mode,
      },
    );
  }

  function updatePatchActionAvailability() {
    const hasSelectedTree =
      Boolean(selectedTreeId);

    const activePatchTrigger =
      activePatchId
        ? findPatchTrigger(
            activePatchId,
          )
        : null;

    const patchTreeTotal =
      Number(
        activePatchTrigger?.dataset
          .patchSaplings ??
        0,
      ) +
      Number(
        activePatchTrigger?.dataset
          .patchTrees ??
        0,
      );

    const patchIsFull =
      patchTreeTotal >= 20;

    if (editPatchActionButton) {
      editPatchActionButton.disabled =
        currentForestMode !==
          "planting" ||
        hasSelectedTree;
    }

    if (plantTreeActionButton) {
      plantTreeActionButton.disabled =
        currentForestMode !==
          "planting" ||
        hasSelectedTree ||
        patchIsFull;

      const tooltip =
        patchIsFull
          ? "This forest patch already contains 20 trees"
          : "Plant a Tree";

      plantTreeActionButton.title =
        tooltip;

      plantTreeActionButton.dataset.tooltip =
        tooltip;

      plantTreeActionButton.setAttribute(
        "aria-label",
        tooltip,
      );
    }

    if (editTreeActionButton) {
      editTreeActionButton.disabled =
        currentForestMode !==
          "planting" ||
        !hasSelectedTree;
    }

    if (chopTreeActionButton) {
      chopTreeActionButton.disabled =
        currentForestMode !==
          "planting" ||
        !hasSelectedTree;
    }
  }

  function animatePatchAction(
    button: HTMLButtonElement,
  ) {
    if (
      patchActionAnimationTimeout !==
      undefined
    ) {
      window.clearTimeout(
        patchActionAnimationTimeout,
      );
    }

    button.classList.remove(
      "is-activating",
    );

    void button.offsetWidth;

    button.classList.add(
      "is-activating",
    );

    patchActionAnimationTimeout =
      window.setTimeout(
        () => {
          button.classList.remove(
            "is-activating",
          );
        },
        380,
      );
  }

  function requestPatchInspectorAction(
    action: PatchInspectorAction,
    button: HTMLButtonElement,
  ) {
    if (
      currentForestMode !==
        "planting" ||
      button.disabled ||
      !activePatchId
    ) {
      return;
    }

    const requiresTree =
      action === "edit-tree" ||
      action === "chop-tree";

    if (
      requiresTree &&
      !selectedTreeId
    ) {
      return;
    }

    animatePatchAction(
      button,
    );

    const detail:
      PatchInspectorActionDetail = {
        action,
        patchId:
          activePatchId,
      };

    if (selectedTreeId) {
      detail.treeId =
        selectedTreeId;
    }

    window.dispatchEvent(
      new CustomEvent(
        `patch-inspector:${action}`,
        {
          detail,
        },
      ),
    );

    console.log(
      "Patch Inspector action requested:",
      detail,
    );
  }

  patchActionButtons.forEach(
    (button) => {
      button.addEventListener(
        "click",
        () => {
          const action =
            button.dataset
              .patchAction;

          if (
            action !==
              "edit-patch" &&
            action !==
              "plant-tree" &&
            action !==
              "edit-tree" &&
            action !==
              "chop-tree"
          ) {
            return;
          }

          requestPatchInspectorAction(
            action,
            button,
          );
        },
      );
    },
  );

  /* =======================================================
     TREE INFORMATION
     ======================================================= */

  function resetTreeInformation() {
    if (treeName) {
      treeName.textContent =
        "Select a tree";
    }
  
    if (treePlanted) {
      treePlanted.textContent =
        "Not Specified";
    }
  
    if (treeSprouted) {
      treeSprouted.textContent =
        "Not Specified";
    }
  
    if (treeDescription) {
      treeDescription.textContent =
        "Select a tree from the forest patch to view its information.";
    }
  
    if (treeLink) {
      treeLink.href = "";
      treeLink.hidden = true;
    }
  
    if (treeLinkEmpty) {
      treeLinkEmpty.textContent =
        "Not Available";
  
      treeLinkEmpty.hidden = false;
    }
  
    if (treeEvidenceRow) {
      treeEvidenceRow.hidden =
        true;
    }
  }

  function clearTreeSelection() {
    if (!previewCanvas) return;

    previewCanvas
      .querySelectorAll<HTMLElement>(
        ".skill-tree.is-selected",
      )
      .forEach((selectedTree) => {
        selectedTree.classList.remove(
          "is-selected",
        );
      });

    selectedTreeId = null;

    resetTreeInformation();
    updatePatchActionAvailability();
  }

  function formatDate(
    dateValue?: string,
  ): string {
    const trimmedDate =
      dateValue?.trim();

    if (!trimmedDate) {
      return "Not Specified";
    }

    const match =
      trimmedDate.match(
        /^(\d{4})-(\d{2})-(\d{2})$/,
      );

    if (!match) {
      return "Not Specified";
    }

    const [, year, month, day] =
      match;

    const numericYear =
      Number(year);

    const numericMonth =
      Number(month);

    const numericDay =
      Number(day);

    const date = new Date(
      numericYear,
      numericMonth - 1,
      numericDay,
    );

    const isValidDate =
      date.getFullYear() ===
        numericYear &&
      date.getMonth() ===
        numericMonth - 1 &&
      date.getDate() ===
        numericDay;

    if (!isValidDate) {
      return "Not Specified";
    }

    return new Intl.DateTimeFormat(
      "en-US",
      {
        month: "long",
        day: "2-digit",
        year: "numeric",
      },
    ).format(date);
  }

  function selectTree(
    tree: HTMLElement,
    focusTree = false,
  ) {
    if (!previewCanvas) return;

    previewCanvas
      .querySelectorAll<HTMLElement>(
        ".skill-tree.is-selected",
      )
      .forEach((selectedTree) => {
        selectedTree.classList.remove(
          "is-selected",
        );
      });

    tree.classList.add(
      "is-selected",
    );

    selectedTreeId =
      tree.dataset.treeId?.trim() ||
      null;

    updatePatchActionAvailability();

    if (treeName) {
      treeName.textContent =
        tree.dataset.treeName?.trim() ||
        "Unnamed Tree";
    }

    if (treePlanted) {
      treePlanted.textContent =
        formatDate(
          tree.dataset.treeDatePlanted,
        );
    }

    const growthStage =
      tree.dataset
        .treeGrowthStage ===
        "TREE"
        ? "TREE"
        : "SAPLING";
    
    if (treeSprouted) {
      treeSprouted.textContent =
        growthStage ===
          "SAPLING"
          ? "Provide some evidence to see your tree grow"
          : formatDate(
              tree.dataset
                .treeDateSprouted,
            );
    }
    
    if (treeDescription) {
      treeDescription.textContent =
        tree.dataset.treeDescription?.trim() ||
        "No description has been provided.";
    }
    
    const evidencePath =
      tree.dataset
        .treeEvidencePath
        ?.trim();
    
    if (treeEvidenceRow) {
      treeEvidenceRow.hidden =
        growthStage !==
        "TREE";
    }
    
    if (
      treeLink &&
      treeLinkEmpty
    ) {
      if (
        growthStage ===
          "TREE" &&
        evidencePath
      ) {
        treeLink.href =
          /^https?:\/\//i.test(evidencePath)
            ? evidencePath
            : `${baseUrl}${evidencePath.replace(/^\/+/, "")}`;
    
        treeLink.hidden =
          false;
    
        treeLinkEmpty.hidden =
          true;
      } else {
        treeLink.href = "";
        treeLink.hidden = true;
    
        treeLinkEmpty.textContent =
          "Not Available";
    
        treeLinkEmpty.hidden =
          false;
      }
    }

    if (focusTree) {
      tree.focus({
        preventScroll: true,
      });
    }
  }

  /* =======================================================
     PATCH VIEWER
     ======================================================= */

  function findPatchTrigger(
    patchId: string,
  ): HTMLElement | null {
    const triggers =
      document.querySelectorAll<HTMLElement>(
        "[data-patch-viewer-trigger]",
      );

    for (const trigger of triggers) {
      if (
        trigger.dataset.patchId ===
        patchId
      ) {
        return trigger;
      }
    }

    return null;
  }

  function findClonedTree(
    treeId: string,
  ): HTMLElement | null {
    if (!previewCanvas) {
      return null;
    }

    const trees =
      previewCanvas.querySelectorAll<HTMLElement>(
        ".skill-tree",
      );

    for (const tree of trees) {
      if (
        tree.dataset.treeId ===
        treeId
      ) {
        return tree;
      }
    }

    return null;
  }

  function openPatchViewer(
    trigger: HTMLElement,
    requestedTreeId?: string,
  ) {
    if (
      !overlay ||
      !previewCanvas
    ) {
      return;
    }

    activePatchId =
      trigger.dataset.patchId?.trim() ||
      null;

    selectedTreeId = null;

    updatePatchInspectorMode(
      document.body.dataset
        .currentMode === "planting"
        ? "planting"
        : "strolling",
    );

    previouslyFocusedElement =
      document.activeElement instanceof
      HTMLElement
        ? document.activeElement
        : null;

    if (title) {
      title.textContent =
        trigger.dataset.patchName?.trim() ||
        "Forest Patch";
    }

    if (saplingCount) {
      saplingCount.textContent =
        trigger.dataset.patchSaplings?.trim() ||
        "0";
    }

    if (treeCount) {
      treeCount.textContent =
        trigger.dataset.patchTrees?.trim() ||
        "0";
    }

    previewCanvas.replaceChildren();

    resetTreeInformation();

    const patchClone =
      trigger.cloneNode(
        true,
      ) as HTMLElement;

    patchClone.removeAttribute(
      "data-patch-viewer-trigger",
    );

    patchClone.removeAttribute(
      "tabindex",
    );

    patchClone.removeAttribute(
      "role",
    );

    patchClone
      .querySelector<HTMLElement>(
        ".patch-label",
      )
      ?.remove();

    patchClone
      .querySelector<HTMLElement>(
        ".patch-description",
      )
      ?.remove();

    const clonedTrees =
      patchClone.querySelectorAll<HTMLElement>(
        ".skill-tree",
      );

    clonedTrees.forEach((tree) => {
      tree.setAttribute(
        "role",
        "button",
      );

      tree.setAttribute(
        "tabindex",
        "0",
      );

      tree.setAttribute(
        "aria-label",
        tree.dataset.treeName?.trim() ||
        "Forest tree",
      );

      tree.addEventListener(
        "click",
        (event) => {
          event.stopPropagation();

          selectTree(tree);
        },
      );

      tree.addEventListener(
        "keydown",
        (event) => {
          if (
            event.key === "Enter" ||
            event.key === " "
          ) {
            event.preventDefault();
            event.stopPropagation();

            selectTree(tree);
          }
        },
      );
    });

    previewCanvas.appendChild(
      patchClone,
    );

    overlay.classList.add(
      "is-open",
    );

    overlay.setAttribute(
      "aria-hidden",
      "false",
    );

    document.body.style.overflow =
      "hidden";

    if (requestedTreeId) {
      const selectedTree =
        findClonedTree(
          requestedTreeId,
        );

      if (selectedTree) {
        selectTree(
          selectedTree,
          true,
        );
      } else {
        console.warn(
          `Tree ${requestedTreeId} was not found inside patch ${trigger.dataset.patchId}.`,
        );

        closeButton?.focus();
      }
    } else {
      closeButton?.focus();
    }

    console.log(
      "Patch viewer opened:",
      {
        patchId:
          trigger.dataset.patchId,
        patchName:
          trigger.dataset.patchName,
        selectedTreeId:
          requestedTreeId ?? null,
      },
    );
  }

  function closePatchViewer() {
    if (!overlay) return;

    overlay.classList.remove(
      "is-open",
    );

    overlay.setAttribute(
      "aria-hidden",
      "true",
    );

    document.body.style.overflow =
      "";

    clearTreeSelection();

    activePatchId = null;
    selectedTreeId = null;

    updatePatchActionAvailability();

    previouslyFocusedElement?.focus({
      preventScroll: true,
    });

    previouslyFocusedElement = null;

    console.log(
      "Patch viewer closed.",
    );
  }

  /* =======================================================
     PREVIEW INTERACTION
     ======================================================= */

  previewCanvas?.addEventListener(
    "click",
    (event) => {
      const target =
        event.target as HTMLElement;

      if (
        target.closest(
          ".skill-tree",
        )
      ) {
        return;
      }

      clearTreeSelection();
    },
  );

  /* =======================================================
     DIRECT PATCH CLICKS
     ======================================================= */

  document
    .querySelectorAll<HTMLElement>(
      "[data-patch-viewer-trigger]",
    )
    .forEach((trigger) => {
      trigger.addEventListener(
        "click",
        () => {
          if (document.body.dataset.deletePatchMode === "true") return;
          openPatchViewer(
            trigger,
          );
        },
      );

      trigger.addEventListener(
        "keydown",
        (event) => {
          if (
            event.key === "Enter" ||
            event.key === " "
          ) {
            event.preventDefault();

            openPatchViewer(
              trigger,
            );
          }
        },
      );
    });

  /* =======================================================
     PROGRAMMATIC OPENING

     Tree Search will dispatch:

     window.dispatchEvent(
       new CustomEvent("patch-viewer:open", {
         detail: {
           patchId: "...",
           treeId: "...",
         },
       }),
     );
     ======================================================= */

  window.addEventListener(
    "patch-viewer:open",
    (event) => {
      const customEvent =
        event as CustomEvent<
          OpenPatchViewerDetail
        >;

      const patchId =
        customEvent.detail?.patchId?.trim();

      const treeId =
        customEvent.detail?.treeId?.trim();

      if (!patchId) {
        console.warn(
          "Patch viewer request did not include a patch ID.",
        );

        return;
      }

      const trigger =
        findPatchTrigger(
          patchId,
        );

      if (!trigger) {
        console.warn(
          `Patch ${patchId} was not found.`,
        );

        return;
      }

      openPatchViewer(
        trigger,
        treeId || undefined,
      );
    },
  );

  /* =======================================================
     FOREST MODE UPDATES
     ======================================================= */

  window.addEventListener(
    "forest:mode-changed",
    (
      event: Event,
    ) => {
      const customEvent =
        event as CustomEvent<
          ForestModeChangedDetail
        >;

      const mode =
        customEvent.detail?.mode;

      if (
        mode !== "strolling" &&
        mode !== "planting"
      ) {
        return;
      }

      updatePatchInspectorMode(
        mode,
      );
    },
  );

  /* =======================================================
     PATCH UPDATE REFRESH
     ======================================================= */

  window.addEventListener(
    "forest:patch-updated",
    (
      event: Event,
    ) => {
      const customEvent =
        event as CustomEvent<{
          patch?: {
            Patch_ID: string;
          };
        }>;

      const updatedPatchId =
        customEvent.detail
          ?.patch
          ?.Patch_ID
          ?.trim();

      if (
        !updatedPatchId ||
        updatedPatchId !==
          activePatchId ||
        !overlay?.classList.contains(
          "is-open",
        )
      ) {
        return;
      }

      window.requestAnimationFrame(
        () => {
          const trigger =
            findPatchTrigger(
              updatedPatchId,
            );

          if (!trigger) {
            return;
          }

          /*
            Rebuild the open inspector from the newly updated
            world patch while keeping the parent dialog open.
          */

          openPatchViewer(
            trigger,
          );

          console.log(
            "Open Patch Inspector refreshed after patch update:",
            {
              patchId:
                updatedPatchId,
            },
          );
        },
      );
    },
  );

  /* =======================================================
     TREE ADDED REFRESH
     ======================================================= */

  window.addEventListener(
    "forest:tree-added",
    (
      event: Event,
    ) => {
      const customEvent =
        event as CustomEvent<{
          tree?: {
            Tree_ID: string;
            Patch_ID: string;
          };
        }>;

      const tree =
        customEvent.detail
          ?.tree;

      if (
        !tree ||
        tree.Patch_ID !==
          activePatchId ||
        !overlay?.classList.contains(
          "is-open",
        )
      ) {
        return;
      }

      window.requestAnimationFrame(
        () => {
          const trigger =
            findPatchTrigger(
              tree.Patch_ID,
            );

          if (!trigger) {
            return;
          }

          openPatchViewer(
            trigger,
            tree.Tree_ID,
          );
        },
      );
    },
  );

  window.addEventListener("forest:tree-updated", (event: Event) => {
    const tree = (event as CustomEvent<{tree?: {Tree_ID:string;Patch_ID:string}}>).detail?.tree;
    if (!tree || tree.Patch_ID !== activePatchId || !overlay?.classList.contains("is-open")) return;
    requestAnimationFrame(() => { const trigger=findPatchTrigger(tree.Patch_ID); if(trigger) openPatchViewer(trigger, tree.Tree_ID); });
  });

  window.addEventListener("forest:tree-deleted", (event: Event) => {
    const patch = (event as CustomEvent<{patch?: {Patch_ID:string}}>).detail?.patch;
    if (!patch || patch.Patch_ID !== activePatchId || !overlay?.classList.contains("is-open")) return;
    requestAnimationFrame(() => { const trigger=findPatchTrigger(patch.Patch_ID); if(trigger) openPatchViewer(trigger); });
  });

  window.addEventListener("forest:patch-deleted", (event: Event) => {
    const patchId = (event as CustomEvent<{patchId?:string}>).detail?.patchId;
    if (patchId && patchId === activePatchId) closePatchViewer();
  });

  /* =======================================================
     CLOSE CONTROLS
     ======================================================= */

  closeButton?.addEventListener(
    "click",
    closePatchViewer,
  );

  document.addEventListener(
    "keydown",
    (event) => {
      const childDialogOpen =
        document.querySelector(
          "[data-edit-patch-overlay].is-open, [data-plant-tree-overlay].is-open, [data-edit-tree-overlay].is-open, [data-chop-tree-overlay].is-open, [data-delete-patch-overlay].is-open",
        );

      if (
        event.key === "Escape" &&
        !childDialogOpen &&
        overlay?.classList.contains(
          "is-open",
        )
      ) {
        closePatchViewer();
      }
    },
  );

  updatePatchInspectorMode(
    currentForestMode,
  );
</script>