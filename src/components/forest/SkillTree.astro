---
import treeSlots from "../../data/tree_slots.json";

interface Props {
  treeId: string;
  treeName: string;
  treeDescription: string;
  datePlanted: string;
  dateSprouted: string;
  evidencePath: string;
  patchStyle: string;
  growthStage: "SAPLING" | "TREE";
  displaySlot: number;
  patchScale?: number;
}

const {
  treeId,
  treeName,
  treeDescription,
  datePlanted,
  dateSprouted,
  evidencePath,
  patchStyle,
  growthStage,
  displaySlot,
  patchScale = 0.40,
} = Astro.props;

const slot = treeSlots.find(
  (record) => Number(record.Display_Slot) === displaySlot,
);

if (!slot) {
  throw new Error(`Tree slot ${displaySlot} was not found.`);
}

const normalizedPatchStyle = patchStyle.padStart(2, "0");

const treeStyleNumber = ((displaySlot - 1) % 3) + 1;
const normalizedTreeStyle = String(treeStyleNumber).padStart(2, "0");

const assetPrefix =
  growthStage === "TREE" ? "Tree" : "Sapling";

const assetFolder =
  growthStage === "TREE" ? "trees" : "saplings";

const assetPath =
  `/assets/${assetFolder}/${assetPrefix}_${normalizedPatchStyle}_${normalizedTreeStyle}.png`;

const nativeWidth = growthStage === "TREE" ? 295 : 177;
const nativeHeight = growthStage === "TREE" ? 414 : 236;

const treeAssetScale = 0.70;

const displayWidth =
  nativeWidth * patchScale * treeAssetScale;

const displayHeight =
  nativeHeight * patchScale * treeAssetScale;

const xPercent = Number(slot.X_Normalized) * 100;
const yPercent = Number(slot.Y_Normalized) * 100;
const renderOrder = Number(slot.Render_Order);
---

<div
  class="skill-tree"
  data-tree-id={treeId}
  data-tree-name={treeName}
  data-tree-description={treeDescription}
  data-tree-date-planted={datePlanted}
  data-tree-date-sprouted={dateSprouted}
  data-tree-evidence-path={evidencePath}
  data-tree-growth-stage={growthStage}
  data-tree-display-slot={displaySlot}
  style={`
    left: ${xPercent}%;
    top: ${yPercent}%;
    width: ${displayWidth}px;
    height: ${displayHeight}px;
    z-index: ${renderOrder};
  `}
>
  <img
    src={assetPath}
    alt={treeName}
    draggable="false"
  />
</div>

<style>
  .skill-tree {
    position: absolute;
    transform: translate(-50%, -100%);
    transform-origin: 50% 100%;
    pointer-events: auto;
    user-select: none;
  }

  .skill-tree img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    pointer-events: none;
    user-select: none;
    -webkit-user-drag: none;
  }
</style>