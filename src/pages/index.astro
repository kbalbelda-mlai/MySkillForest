---
import { loadForestPatches } from "../scripts/loadForestData";
import ForestWorld from "../components/forest/ForestWorld.astro";

const pageTitle = "My Skill Forest";
const forestPatches = loadForestPatches();

console.log(forestPatches);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
  </head>

  <body>
    <header class="header-ribbon">
      <div class="mode-button">Strolling Mode</div>

      <nav class="main-nav">
        <button type="button">Home</button>
        <button type="button">Tree Search</button>
      </nav>

      <div class="forest-stats">
        <span>Patches: 7</span>
        <span>Saplings: 0</span>
        <span>Trees: 0</span>
      </div>
    </header>

    <main class="forest-viewport">
      <div class="forest-world">
        
		<ForestWorld />

      </div>
    </main>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html),
  :global(body) {
    width: 100%;
    height: 100%;
    margin: 0;
    overflow: hidden;
    font-family: Arial, sans-serif;
  }

  body {
    display: flex;
    flex-direction: column;
    background: #b8dce8;
  }

  .header-ribbon {
    height: 64px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 0 20px;
    background: rgba(255, 255, 255, 0.94);
    border-bottom: 1px solid rgba(0, 0, 0, 0.15);
    z-index: 100;
  }

  .mode-button {
    padding: 10px 14px;
    border-radius: 8px;
    background: #dcefdc;
    font-weight: 700;
  }

  .main-nav {
    display: flex;
    gap: 10px;
  }

  .main-nav button {
    border: 0;
    background: transparent;
    padding: 10px 12px;
    cursor: pointer;
    font-size: 15px;
  }

  .forest-stats {
    margin-left: auto;
    display: flex;
    gap: 18px;
    font-size: 14px;
  }

  .forest-viewport {
    position: relative;
    flex: 1;
    overflow: hidden;
    background: #b8dce8;
  }

</style>