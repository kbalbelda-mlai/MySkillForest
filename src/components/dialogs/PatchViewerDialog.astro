---
interface Props {
  dialogId?: string;
}

const {
  dialogId = "patch-viewer-dialog",
} = Astro.props;
---

<div
  id={dialogId}
  class="patch-viewer-overlay"
  aria-hidden="true"
  data-patch-viewer-overlay
>
  <section
    class="patch-viewer-dialog"
    role="dialog"
    aria-modal="true"
    aria-labelledby="patch-viewer-title"
  >
    <button
      class="close-button"
      type="button"
      aria-label="Close forest patch viewer"
      data-close-patch-viewer
    >
      ×
    </button>

    <div class="patch-preview-panel">
      <div
        class="patch-preview-canvas"
        data-patch-preview-canvas
      ></div>
    </div>

    <div class="patch-information-panel">
      <h2 id="patch-viewer-title">
        Forest Patch Name
      </h2>

      <div class="patch-counts">
        <p>
          <strong>Saplings:</strong>
          <span data-patch-saplings>0</span>
        </p>

        <p>
          <strong>Trees:</strong>
          <span data-patch-trees>0</span>
        </p>
      </div>

      <div class="tree-information">
        <h3 data-tree-name>
          Select a tree
        </h3>

        <p>
          <strong>Planted on:</strong>
          <span data-tree-planted>
            Not Specified
          </span>
        </p>

        <p>
          <strong>Sprouted on:</strong>
          <span data-tree-sprouted>
            Not Specified
          </span>
        </p>

        <p>
          <strong>Evidence:</strong>

          <a
            data-tree-link
            href=""
            target="_blank"
            rel="noopener noreferrer"
            hidden
          >
            Open evidence
          </a>

          <span data-tree-link-empty>
            Not Available
          </span>
        </p>

        <div class="tree-description">
          <strong>Tree description</strong>

          <p data-tree-description>
            Select a tree from the forest patch to view its information.
          </p>
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  /* =======================================================
     OVERLAY
     ======================================================= */

  .patch-viewer-overlay {
    position: fixed;
    inset: 0;
    z-index: 5000;

    display: grid;
    place-items: center;

    padding: 40px;

    background:
      rgba(5, 38, 52, 0.82);

    backdrop-filter: blur(4px);

    opacity: 0;
    visibility: hidden;
    pointer-events: none;

    transition:
      opacity 220ms ease,
      visibility 220ms ease;
  }

  .patch-viewer-overlay.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  /* =======================================================
     DIALOG
     ======================================================= */

  .patch-viewer-dialog {
    position: relative;

    display: grid;
    grid-template-columns:
      minmax(420px, 1.1fr)
      minmax(340px, 0.9fr);

    gap: 48px;

    width: min(1180px, 92vw);
    height: min(650px, 84vh);

    padding: 34px;

    background:
      rgba(255, 255, 255, 0.97);

    border-radius: 28px;

    box-shadow:
      0 24px 70px
      rgba(0, 0, 0, 0.35);

    transform:
      translateY(18px)
      scale(0.97);

    transition:
      transform 220ms ease;
  }

  .patch-viewer-overlay.is-open
  .patch-viewer-dialog {
    transform:
      translateY(0)
      scale(1);
  }

  /* =======================================================
     CLOSE BUTTON
     ======================================================= */

  .close-button {
    position: absolute;
    top: -28px;
    right: -28px;
    z-index: 20;

    width: 82px;
    height: 82px;

    border:
      2px solid #082b3a;

    border-radius: 50%;

    background: #176887;
    color: white;

    font-size: 54px;
    font-weight: 300;
    line-height: 1;

    cursor: pointer;

    transition:
      transform 160ms ease,
      background 160ms ease;
  }

  .close-button:hover {
    transform: scale(1.06);
    background: #1d789b;
  }

  .close-button:focus-visible {
    outline:
      4px solid
      rgba(104, 209, 255, 0.9);

    outline-offset: 4px;
  }

  /* =======================================================
     PATCH PREVIEW
     ======================================================= */

  .patch-preview-panel {
    position: relative;
    min-width: 0;
    min-height: 0;

    display: grid;
    place-items: center;

    overflow: visible;

    border:
      3px solid #0a2d3d;

    border-radius: 26px;

    background: #eaf5f8;
  }

  .patch-preview-canvas {
    position: relative;

    width: min(500px, 86%);

    aspect-ratio: 1;

    overflow: visible;
  }

  .patch-preview-canvas
  :global(.forest-patch) {
    left: 50% !important;
    top: 52% !important;

    cursor: default;

    transform:
      translate(-50%, -50%)
      scale(1.12);
  }

  .patch-preview-canvas
  :global(.patch-label) {
    display: none;
  }

  .patch-preview-canvas
  :global(.ground-patch) {
    transform: none;
    filter: none;
    pointer-events: none;
  }

  .patch-preview-canvas
  :global(
    .forest-patch:hover
    .ground-patch
  ) {
    transform: none !important;
    filter: none !important;
  }

  /* =======================================================
     PATCH DESCRIPTION
     ======================================================= */

  .patch-description-bubble {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 6000;

    width: 100%;

    padding:
      16px 22px;

    border-top:
      1px solid
      rgba(40, 127, 177, 0.4);

    background:
      linear-gradient(
        135deg,
        rgba(232, 250, 255, 0.97),
        rgba(190, 228, 248, 0.97)
      );

    box-shadow:
      0 -8px 24px
      rgba(20, 77, 108, 0.16);

    color: #103b54;

    font-size: 15px;
    font-weight: 600;
    line-height: 1.45;

    text-align: center;

    opacity: 0;
    visibility: hidden;

    transform:
      translateY(100%);

    pointer-events: none;

    transition:
      opacity 180ms ease,
      visibility 180ms ease,
      transform 180ms ease;
  }

  .patch-preview-panel:hover
  .patch-description-bubble,
  .patch-preview-panel:focus-within
  .patch-description-bubble {
    opacity: 1;
    visibility: visible;

    transform:
      translateY(0);
  }

  /* =======================================================
     INTERACTIVE TREES
     ======================================================= */

  .patch-preview-canvas
  :global(.skill-tree) {
    cursor: pointer;
    pointer-events: auto;

    transition:
      transform 180ms ease,
      filter 180ms ease;
  }

  .patch-preview-canvas
  :global(.skill-tree img) {
    pointer-events: none;
  }

  .patch-preview-canvas
  :global(.skill-tree:hover),
  .patch-preview-canvas
  :global(.skill-tree.is-selected) {
    filter:
      drop-shadow(
        0 0 2px
        rgba(219, 248, 255, 1)
      )
      drop-shadow(
        0 0 6px
        rgba(93, 211, 255, 0.95)
      )
      drop-shadow(
        0 0 12px
        rgba(56, 128, 255, 0.78)
      );

    animation:
      tree-blue-glow
      1.4s ease-in-out
      infinite alternate;
  }

  .patch-preview-canvas
  :global(.skill-tree:hover) {
    transform:
      translate(-50%, -100%)
      translateY(-4px)
      scale(1.045);
  }

  .patch-preview-canvas
  :global(.skill-tree.is-selected) {
    transform:
      translate(-50%, -100%)
      scale(1.025);
  }

  .patch-preview-canvas
  :global(.skill-tree:focus-visible) {
    outline: none;

    filter:
      drop-shadow(
        0 0 3px
        rgba(232, 252, 255, 1)
      )
      drop-shadow(
        0 0 9px
        rgba(93, 211, 255, 1)
      )
      drop-shadow(
        0 0 16px
        rgba(56, 128, 255, 0.9)
      );
  }

  /* =======================================================
     TREE HOVER LABEL
     ======================================================= */

  .patch-preview-canvas
  :global(.skill-tree::after) {
    content:
      attr(data-tree-name);

    position: absolute;
    left: 50%;
    bottom:
      calc(100% + 8px);

    z-index: 7000;

    transform:
      translate(-50%, 6px);

    padding:
      6px 10px;

    border:
      1px solid
      rgba(40, 127, 177, 0.65);

    border-radius: 8px;

    background:
      linear-gradient(
        135deg,
        rgba(232, 250, 255, 0.98),
        rgba(185, 225, 255, 0.98)
      );

    box-shadow:
      0 5px 15px
      rgba(26, 92, 133, 0.24);

    color: #103b54;

    font-size: 12px;
    font-weight: 700;
    line-height: 1.2;

    white-space: nowrap;

    opacity: 0;
    visibility: hidden;

    pointer-events: none;

    transition:
      opacity 150ms ease,
      transform 150ms ease,
      visibility 150ms ease;
  }

  .patch-preview-canvas
  :global(
    .skill-tree:hover::after
  ),
  .patch-preview-canvas
  :global(
    .skill-tree.is-selected::after
  ),
  .patch-preview-canvas
  :global(
    .skill-tree:focus-visible::after
  ) {
    opacity: 1;
    visibility: visible;

    transform:
      translate(-50%, 0);
  }

  @keyframes tree-blue-glow {
    from {
      filter:
        drop-shadow(
          0 0 2px
          rgba(219, 248, 255, 0.9)
        )
        drop-shadow(
          0 0 5px
          rgba(93, 211, 255, 0.75)
        )
        drop-shadow(
          0 0 9px
          rgba(56, 128, 255, 0.6)
        );
    }

    to {
      filter:
        drop-shadow(
          0 0 3px
          rgba(232, 252, 255, 1)
        )
        drop-shadow(
          0 0 8px
          rgba(93, 211, 255, 1)
        )
        drop-shadow(
          0 0 16px
          rgba(56, 128, 255, 0.88)
        );
    }
  }

  /* =======================================================
     INFORMATION PANEL
     ======================================================= */

  .patch-information-panel {
    min-width: 0;

    overflow-y: auto;

    padding:
      10px 8px 10px 0;
  }

  .patch-information-panel h2 {
    margin:
      0 0 24px;

    max-width: 100%;

    font-size:
      clamp(26px, 3vw, 42px);

    line-height: 1.08;

    overflow-wrap: anywhere;
    word-break: normal;
    text-wrap: balance;
  }

  .patch-counts {
    display: flex;
    flex-wrap: wrap;

    gap:
      12px 56px;

    margin-bottom: 42px;

    font-size: 20px;
  }

  .patch-counts p {
    margin: 0;
  }

  .patch-counts strong,
  .tree-information > p strong {
    margin-right: 0.3rem;
  }

  .tree-information h3 {
    margin:
      0 0 26px;

    font-size: 25px;

    overflow-wrap: anywhere;
  }

  .tree-information > p {
    margin:
      0 0 20px;

    font-size: 18px;
  }

  .tree-information a {
    color: #176887;
    font-weight: 700;
  }

  .tree-description {
    margin-top: 42px;

    font-size: 18px;
  }

  .tree-description p {
    margin-top: 12px;

    line-height: 1.55;
    overflow-wrap: anywhere;
  }

  /* =======================================================
     RESPONSIVE VIEW
     ======================================================= */

  @media (max-width: 850px) {
    .patch-viewer-overlay {
      padding: 22px;
    }

    .patch-viewer-dialog {
      grid-template-columns: 1fr;

      grid-template-rows:
        minmax(280px, 1fr)
        auto;

      width: 94vw;
      height: 90vh;

      gap: 24px;
      padding: 24px;

      overflow-y: auto;
    }

    .close-button {
      top: -14px;
      right: -10px;

      width: 58px;
      height: 58px;

      font-size: 38px;
    }

    .patch-preview-panel {
      min-height: 340px;
    }

    .patch-preview-canvas {
      width:
        min(460px, 92%);
    }

    .patch-preview-canvas
    :global(.patch-description) {
      display: none !important;
    }

    .patch-information-panel {
      overflow: visible;
    }
  }
</style>

<script>
  /* =======================================================
     TYPES
     ======================================================= */

  interface OpenPatchViewerDetail {
    patchId: string;
    treeId?: string;
  }

  /* =======================================================
     ELEMENT REFERENCES
     ======================================================= */

  const overlay =
    document.querySelector<HTMLElement>(
      "#patch-viewer-dialog",
    );

  const closeButton =
    overlay?.querySelector<HTMLButtonElement>(
      "[data-close-patch-viewer]",
    );

  const title =
    overlay?.querySelector<HTMLElement>(
      "#patch-viewer-title",
    );

  const saplingCount =
    overlay?.querySelector<HTMLElement>(
      "[data-patch-saplings]",
    );

  const treeCount =
    overlay?.querySelector<HTMLElement>(
      "[data-patch-trees]",
    );

  const previewCanvas =
    overlay?.querySelector<HTMLElement>(
      "[data-patch-preview-canvas]",
    );

  const treeName =
    overlay?.querySelector<HTMLElement>(
      "[data-tree-name]",
    );

  const treePlanted =
    overlay?.querySelector<HTMLElement>(
      "[data-tree-planted]",
    );

  const treeSprouted =
    overlay?.querySelector<HTMLElement>(
      "[data-tree-sprouted]",
    );

  const treeDescription =
    overlay?.querySelector<HTMLElement>(
      "[data-tree-description]",
    );

  const treeLink =
    overlay?.querySelector<HTMLAnchorElement>(
      "[data-tree-link]",
    );

  const treeLinkEmpty =
    overlay?.querySelector<HTMLElement>(
      "[data-tree-link-empty]",
    );

  let previouslyFocusedElement:
    HTMLElement | null = null;

  /* =======================================================
     TREE INFORMATION
     ======================================================= */

  function resetTreeInformation() {
    if (treeName) {
      treeName.textContent =
        "Select a tree";
    }

    if (treePlanted) {
      treePlanted.textContent =
        "Not Specified";
    }

    if (treeSprouted) {
      treeSprouted.textContent =
        "Not Specified";
    }

    if (treeDescription) {
      treeDescription.textContent =
        "Select a tree from the forest patch to view its information.";
    }

    if (treeLink) {
      treeLink.href = "";
      treeLink.hidden = true;
    }

    if (treeLinkEmpty) {
      treeLinkEmpty.textContent =
        "Not Available";

      treeLinkEmpty.hidden = false;
    }
  }

  function clearTreeSelection() {
    if (!previewCanvas) return;

    previewCanvas
      .querySelectorAll<HTMLElement>(
        ".skill-tree.is-selected",
      )
      .forEach((selectedTree) => {
        selectedTree.classList.remove(
          "is-selected",
        );
      });

    resetTreeInformation();
  }

  function formatDate(
    dateValue?: string,
  ): string {
    const trimmedDate =
      dateValue?.trim();

    if (!trimmedDate) {
      return "Not Specified";
    }

    const match =
      trimmedDate.match(
        /^(\d{4})-(\d{2})-(\d{2})$/,
      );

    if (!match) {
      return "Not Specified";
    }

    const [, year, month, day] =
      match;

    const numericYear =
      Number(year);

    const numericMonth =
      Number(month);

    const numericDay =
      Number(day);

    const date = new Date(
      numericYear,
      numericMonth - 1,
      numericDay,
    );

    const isValidDate =
      date.getFullYear() ===
        numericYear &&
      date.getMonth() ===
        numericMonth - 1 &&
      date.getDate() ===
        numericDay;

    if (!isValidDate) {
      return "Not Specified";
    }

    return new Intl.DateTimeFormat(
      "en-US",
      {
        month: "long",
        day: "2-digit",
        year: "numeric",
      },
    ).format(date);
  }

  function selectTree(
    tree: HTMLElement,
    focusTree = false,
  ) {
    if (!previewCanvas) return;

    previewCanvas
      .querySelectorAll<HTMLElement>(
        ".skill-tree.is-selected",
      )
      .forEach((selectedTree) => {
        selectedTree.classList.remove(
          "is-selected",
        );
      });

    tree.classList.add(
      "is-selected",
    );

    if (treeName) {
      treeName.textContent =
        tree.dataset.treeName?.trim() ||
        "Unnamed Tree";
    }

    if (treePlanted) {
      treePlanted.textContent =
        formatDate(
          tree.dataset.treeDatePlanted,
        );
    }

    if (treeSprouted) {
      treeSprouted.textContent =
        formatDate(
          tree.dataset.treeDateSprouted,
        );
    }

    if (treeDescription) {
      treeDescription.textContent =
        tree.dataset.treeDescription?.trim() ||
        "No description has been provided.";
    }

    const evidencePath =
      tree.dataset.treeEvidencePath?.trim();

    if (
      treeLink &&
      treeLinkEmpty
    ) {
      if (evidencePath) {
        treeLink.href =
          evidencePath;

        treeLink.hidden = false;
        treeLinkEmpty.hidden = true;
      } else {
        treeLink.href = "";
        treeLink.hidden = true;

        treeLinkEmpty.textContent =
          "Not Available";

        treeLinkEmpty.hidden = false;
      }
    }

    if (focusTree) {
      tree.focus({
        preventScroll: true,
      });
    }
  }

  /* =======================================================
     PATCH VIEWER
     ======================================================= */

  function findPatchTrigger(
    patchId: string,
  ): HTMLElement | null {
    const triggers =
      document.querySelectorAll<HTMLElement>(
        "[data-patch-viewer-trigger]",
      );

    for (const trigger of triggers) {
      if (
        trigger.dataset.patchId ===
        patchId
      ) {
        return trigger;
      }
    }

    return null;
  }

  function findClonedTree(
    treeId: string,
  ): HTMLElement | null {
    if (!previewCanvas) {
      return null;
    }

    const trees =
      previewCanvas.querySelectorAll<HTMLElement>(
        ".skill-tree",
      );

    for (const tree of trees) {
      if (
        tree.dataset.treeId ===
        treeId
      ) {
        return tree;
      }
    }

    return null;
  }

  function openPatchViewer(
    trigger: HTMLElement,
    selectedTreeId?: string,
  ) {
    if (
      !overlay ||
      !previewCanvas
    ) {
      return;
    }

    previouslyFocusedElement =
      document.activeElement instanceof
      HTMLElement
        ? document.activeElement
        : null;

    if (title) {
      title.textContent =
        trigger.dataset.patchName?.trim() ||
        "Forest Patch";
    }

    if (saplingCount) {
      saplingCount.textContent =
        trigger.dataset.patchSaplings?.trim() ||
        "0";
    }

    if (treeCount) {
      treeCount.textContent =
        trigger.dataset.patchTrees?.trim() ||
        "0";
    }

    previewCanvas.replaceChildren();

    resetTreeInformation();

    const patchClone =
      trigger.cloneNode(
        true,
      ) as HTMLElement;

    patchClone.removeAttribute(
      "data-patch-viewer-trigger",
    );

    patchClone.removeAttribute(
      "tabindex",
    );

    patchClone.removeAttribute(
      "role",
    );

    patchClone
      .querySelector<HTMLElement>(
        ".patch-label",
      )
      ?.remove();

    patchClone
      .querySelector<HTMLElement>(
        ".patch-description",
      )
      ?.remove();

    const clonedTrees =
      patchClone.querySelectorAll<HTMLElement>(
        ".skill-tree",
      );

    clonedTrees.forEach((tree) => {
      tree.setAttribute(
        "role",
        "button",
      );

      tree.setAttribute(
        "tabindex",
        "0",
      );

      tree.setAttribute(
        "aria-label",
        tree.dataset.treeName?.trim() ||
        "Forest tree",
      );

      tree.addEventListener(
        "click",
        (event) => {
          event.stopPropagation();

          selectTree(tree);
        },
      );

      tree.addEventListener(
        "keydown",
        (event) => {
          if (
            event.key === "Enter" ||
            event.key === " "
          ) {
            event.preventDefault();
            event.stopPropagation();

            selectTree(tree);
          }
        },
      );
    });

    previewCanvas.appendChild(
      patchClone,
    );

    overlay.classList.add(
      "is-open",
    );

    overlay.setAttribute(
      "aria-hidden",
      "false",
    );

    document.body.style.overflow =
      "hidden";

    if (selectedTreeId) {
      const selectedTree =
        findClonedTree(
          selectedTreeId,
        );

      if (selectedTree) {
        selectTree(
          selectedTree,
          true,
        );
      } else {
        console.warn(
          `Tree ${selectedTreeId} was not found inside patch ${trigger.dataset.patchId}.`,
        );

        closeButton?.focus();
      }
    } else {
      closeButton?.focus();
    }

    console.log(
      "Patch viewer opened:",
      {
        patchId:
          trigger.dataset.patchId,
        patchName:
          trigger.dataset.patchName,
        selectedTreeId:
          selectedTreeId ?? null,
      },
    );
  }

  function closePatchViewer() {
    if (!overlay) return;

    overlay.classList.remove(
      "is-open",
    );

    overlay.setAttribute(
      "aria-hidden",
      "true",
    );

    document.body.style.overflow =
      "";

    clearTreeSelection();

    previouslyFocusedElement?.focus({
      preventScroll: true,
    });

    previouslyFocusedElement = null;

    console.log(
      "Patch viewer closed.",
    );
  }

  /* =======================================================
     PREVIEW INTERACTION
     ======================================================= */

  previewCanvas?.addEventListener(
    "click",
    (event) => {
      const target =
        event.target as HTMLElement;

      if (
        target.closest(
          ".skill-tree",
        )
      ) {
        return;
      }

      clearTreeSelection();
    },
  );

  /* =======================================================
     DIRECT PATCH CLICKS
     ======================================================= */

  document
    .querySelectorAll<HTMLElement>(
      "[data-patch-viewer-trigger]",
    )
    .forEach((trigger) => {
      trigger.addEventListener(
        "click",
        () => {
          openPatchViewer(
            trigger,
          );
        },
      );

      trigger.addEventListener(
        "keydown",
        (event) => {
          if (
            event.key === "Enter" ||
            event.key === " "
          ) {
            event.preventDefault();

            openPatchViewer(
              trigger,
            );
          }
        },
      );
    });

  /* =======================================================
     PROGRAMMATIC OPENING

     Tree Search will dispatch:

     window.dispatchEvent(
       new CustomEvent("patch-viewer:open", {
         detail: {
           patchId: "...",
           treeId: "...",
         },
       }),
     );
     ======================================================= */

  window.addEventListener(
    "patch-viewer:open",
    (event) => {
      const customEvent =
        event as CustomEvent<
          OpenPatchViewerDetail
        >;

      const patchId =
        customEvent.detail?.patchId?.trim();

      const treeId =
        customEvent.detail?.treeId?.trim();

      if (!patchId) {
        console.warn(
          "Patch viewer request did not include a patch ID.",
        );

        return;
      }

      const trigger =
        findPatchTrigger(
          patchId,
        );

      if (!trigger) {
        console.warn(
          `Patch ${patchId} was not found.`,
        );

        return;
      }

      openPatchViewer(
        trigger,
        treeId || undefined,
      );
    },
  );

  /* =======================================================
     CLOSE CONTROLS
     ======================================================= */

  closeButton?.addEventListener(
    "click",
    closePatchViewer,
  );

  overlay?.addEventListener(
    "click",
    (event) => {
      if (
        event.target === overlay
      ) {
        closePatchViewer();
      }
    },
  );

  document.addEventListener(
    "keydown",
    (event) => {
      if (
        event.key === "Escape" &&
        overlay?.classList.contains(
          "is-open",
        )
      ) {
        closePatchViewer();
      }
    },
  );
</script>